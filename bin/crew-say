#!/usr/bin/env bash
# crew-say - send a follow-up message (an answer to a blocker, a course
# correction, a peer hand-off) into a crew member's live claude session via tmux.
# The session resumes with full context.
#
# Team guardrail: collaboration stays within a team. The caller (identified by its
# own $WINGMAN_CREW_ID; empty for wingman) may message only:
#   - its own direct reports        (wingman -> its top level; a lead -> its workers)
#   - a sibling under the same lead  (worker <-> worker peer collaboration)
#   - its own lead                   (a worker talking up its chain)
# Anything else is refused so a worker cannot reach arbitrary crew elsewhere in the
# tree. Discover legitimate siblings with `crew-list --owner <your-own-parent>`.
# The verdict logic lives in wm_team_guardrail (lib/common.sh), shared with
# crew-ask so both honour one policy. Pass --force (or set WM_TEAM_FORCE=1, or the
# legacy WM_CREW_SAY_FORCE=1) to override, e.g. for a human operator.
#
# Usage: crew-say [--force] <id> "<message>"
# bash-3.2-safe.
set -u
. "$(dirname "$0")/lib/common.sh"

FORCE=0
if [ "${1:-}" = "--force" ]; then FORCE=1; shift; fi

ID="${1:-}"; MSG="${2:-}"
[ -n "$ID" ] || wm_die "usage: crew-say [--force] <id> \"<message>\""
[ -n "$MSG" ] || wm_die "usage: crew-say [--force] <id> \"<message>\""

# --- team guardrail ---------------------------------------------------------
if [ "$FORCE" != 1 ] && [ -z "${WM_TEAM_FORCE:-}" ] && [ -z "${WM_CREW_SAY_FORCE:-}" ]; then
  CALLER="${WINGMAN_CREW_ID:-}"
  verdict="$(wm_team_guardrail "$CALLER" "$ID")"
  if [ "$verdict" = deny ]; then
    who="${CALLER:-wingman}"
    wm_die "team guardrail: '$who' may only message its own reports, a sibling under the same lead, or its lead (refused '$ID'). Find siblings with crew-list --owner <your-parent>; pass --force to override."
  fi
fi

WINDOW="wm-$ID"
wm_tmux list-windows -t "$WM_TMUX_SESSION" -F '#{window_name}' 2>/dev/null \
  | grep -qx "$WINDOW" || wm_die "no live window for '$ID' (see: bin/crew-takeover $ID)"

wm_tmux_send_message "$WM_TMUX_SESSION:$WINDOW" "$MSG"
wm_ok "delivered to $ID"
