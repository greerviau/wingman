#!/usr/bin/env bash
# spawn-crew - the core recipe: launch one crew member as an independent,
# interactive claude session in its own tmux window, in the target repo.
#
# Usage:
#   spawn-crew --type <software-analyst|architect|developer|reviewer|lead> (--repo <path-or-name> | --scope global) \
#              --objective "<what to do>" \
#              [--id <slug>] [--input <plan-or-report-path>] \
#              [--model <alias|id>] [--effort <low|medium|high|xhigh|max>] \
#              [--allow-merge] [--waive-review-gate] [--force-during-outage] \
#              [--force-during-usage-limit]
#
# --repo grounds the member in one git checkout (the default). --scope global
# grounds it at the workspace root with every discovered repo added, so it can work
# across repos and pick its target(s) itself (for cross-repo work or an unclear
# repo). Prints the crew id on success. All tmux calls are confined to this file and
# lib/common.sh so a future session backend is a localized change.
#
# Model selection: an explicit --model always wins; otherwise $WM_MODEL (if set)
# is the default for every spawn; with neither, the agent CLI's own default stands.
#
# --allow-merge (issue #46): grants THIS member merge autonomy for its own effort
# from the moment it spawns - hooks/no-merge-guard.sh otherwise denies `gh pr
# merge` and equivalents from every crew session by default. Explicit (only ever
# set here, by the caller spawning the member, never by the member itself),
# per-effort (recorded on this one crew record, nothing global), and visible
# (`bin/crew-list` / board.md show it). Omit it (the default) and grant later
# instead if the decision to allow a merge is made mid-session: `$WINGMAN_STATE
# crew-set --id <id> --allow-merge true` takes effect on the member's very next
# merge attempt, no respawn required.
#
# --waive-review-gate (issue #132): once --allow-merge is granted,
# hooks/no-merge-guard.sh also requires verifiable evidence of a genuinely
# separate approving review before a merge attempt succeeds - see the hook's
# own header for the two shapes it accepts. --waive-review-gate is the
# explicit, per-effort escape hatch for the legitimate case where the
# requester has personally examined the diff and wants no review round at
# all; same actor restriction as --allow-merge (never settable by the member
# on itself), same visibility (`bin/crew-list` / board.md show it). Omit it
# (the default) and grant later instead: `$WINGMAN_STATE crew-set --id <id>
# --review-gate-waived true`.
#
# Review-signing token (issue #135, --type reviewer only): a random 32-byte
# token, generated here and held only in the reviewer's own process
# environment (WM_REVIEW_TOKEN) - never written to any file. wm_state
# crew-add derives and stores only its one-way hash commitments, which
# hooks/no-merge-guard.sh's shape-2 check uses to require a matching
# `$WINGMAN_STATE review-sign` proof on a genuine reviewer's comment-fallback
# approve, closing the marker-impersonation gap a later forged comment under
# that reviewer's id would otherwise exploit. Automatic; no flag needed.
#
# Remote Control: every crew member launches Remote-Control-visible by default
# (reachable from claude.ai/code, not only via tmux attach), as name "wm-<id>".
# Set WM_REMOTE_CONTROL= (empty) to disable.
#
# --force-during-outage (issue #23, item 2): the escape hatch for
# hooks/api-outage-spawn-guard.sh, which otherwise denies every spawn-crew
# call while the fleet outage-state ($WM_HOME/api-outage-state.json) reads
# "active". Mirrors --allow-merge's convention exactly: explicit, per-call,
# never inferred. This script itself does nothing with the flag beyond
# accepting it (and noting it in its own success output) - all of the actual
# gating logic lives in the hook, which inspects the raw command line for
# this exact token before this script ever runs.
#
# --force-during-usage-limit (issue #24): the equivalent escape hatch for
# hooks/usage-limit-spawn-guard.sh, which otherwise denies every spawn-crew
# call while the fleet usage-quota-approach state
# ($WM_HOME/usage-limit-state.json) reads "approaching" or "paused". Same
# convention as --force-during-outage: explicit, per-call, never inferred,
# accepted and noted here but gated entirely by the hook itself.
# bash-3.2-safe.
set -u
. "$(dirname "$0")/lib/common.sh"

TYPE=""; REPO_ARG=""; OBJECTIVE=""; ID=""; INPUT=""; MODEL=""; EFFORT=""; SCOPE="repo"; ALLOW_MERGE=0; WAIVE_REVIEW_GATE=0; FORCE_DURING_OUTAGE=0; FORCE_DURING_USAGE_LIMIT=0
while [ $# -gt 0 ]; do
  case "$1" in
    --type)      TYPE="$2"; shift 2 ;;
    --repo)      REPO_ARG="$2"; shift 2 ;;
    --scope)     SCOPE="$2"; shift 2 ;;
    --objective) OBJECTIVE="$2"; shift 2 ;;
    --id)        ID="$2"; shift 2 ;;
    --input)     INPUT="$2"; shift 2 ;;
    --model)     MODEL="$2"; shift 2 ;;
    --effort)    EFFORT="$2"; shift 2 ;;
    --allow-merge) ALLOW_MERGE=1; shift 1 ;;
    --waive-review-gate) WAIVE_REVIEW_GATE=1; shift 1 ;;
    --force-during-outage) FORCE_DURING_OUTAGE=1; shift 1 ;;
    --force-during-usage-limit) FORCE_DURING_USAGE_LIMIT=1; shift 1 ;;
    --list-types) wm_crew_types; exit 0 ;;
    -h|--help)   sed -n '2,23p' "$0"; exit 0 ;;
    *)           wm_die "unknown arg: $1" ;;
  esac
done

# Accept --repo global as an alias for --scope global.
[ "$REPO_ARG" = global ] && { SCOPE="global"; REPO_ARG=""; }
case "$SCOPE" in repo|global) ;; *) wm_die "--scope must be 'repo' or 'global' (got '$SCOPE')" ;; esac

[ -n "$TYPE" ] || wm_die "--type is required (a playbook name; see: spawn-crew --list-types)"
[ -n "$OBJECTIVE" ] || wm_die "--objective is required"

# --- resolve the target scope ------------------------------------------------
# Newline list of every discovered repo path, for --add-dir in global scope.
GLOBAL_REPO_DIRS=""
# Declared before the scope branch (not just before use) so a global-scope spawn
# never trips `set -u` on an unbound variable: global scope leaves these at their
# git-agnostic default (0/0) rather than computing them - see item 5 below for why
# global scope exports neither variable to the member itself.
IS_GIT=0
HAS_REMOTE=0
if [ "$SCOPE" = global ]; then
  [ -z "$REPO_ARG" ] || wm_die "pass either --scope global or --repo <name>, not both"
  # Ground at the primary workspace root (wingman's parent in the common case).
  REPO="$("$WM_BIN/discover-projects" --roots 2>/dev/null | head -n1)"
  [ -n "$REPO" ] && [ -d "$REPO" ] || wm_die "could not resolve a workspace root for global scope (check bin/discover-projects)"
  # Physically normalize (-P), matching repo scope below, so the trust-gate
  # preflight queries the identical string Claude Code itself will key its
  # trust lookup against once the launch script's `cd "$REPO"` runs - a
  # symlinked workspace-root component would otherwise mismatch.
  REPO="$(cd -P "$REPO" && pwd -P)"
  # Refresh the cache, then collect every discovered repo path to add-dir.
  "$WM_BIN/discover-projects" --quiet >/dev/null 2>&1 || true
  GLOBAL_REPO_DIRS="$(wm_state projects-get 2>/dev/null | wm_py -c '
import sys, json
try:
    m = json.load(sys.stdin)
except Exception:
    m = {}
for p in sorted(set(m.values())):
    print(p)
')"
else
  [ -n "$REPO_ARG" ] || wm_die "--repo is required (a path or a discovered project name), or use --scope global"
  # Directory-existence, not git-ness, decides path-vs-name: an explicit path
  # always means the path, git repo or not. Physically normalized (-P) so a
  # symlinked route to a repo root compares equal to the direct route below.
  if [ -d "$REPO_ARG" ]; then
    REPO="$(cd -P "$REPO_ARG" && pwd -P)"
  else
    REPO="$("$WM_BIN/discover-projects" "$REPO_ARG")" || exit 1
    REPO="$(cd -P "$REPO" && pwd -P)"
  fi
  # Git-ness: IS_GIT=1 only when $REPO is the repo's own root, not merely nested
  # inside one (the subdirectory rule - see the plan). --show-toplevel already
  # returns a physical path, but re-normalize anyway rather than depend on that
  # as a guarantee.
  if TOPLEVEL="$(git -C "$REPO" rev-parse --show-toplevel 2>/dev/null)" \
     && TOPLEVEL="$(cd -P "$TOPLEVEL" && pwd -P)" \
     && [ "$TOPLEVEL" = "$REPO" ]; then
    IS_GIT=1
    HAS_REMOTE=0
    git -C "$REPO" remote get-url origin >/dev/null 2>&1 && HAS_REMOTE=1
  else
    IS_GIT=0
    HAS_REMOTE=0
  fi
fi

# True only when this spawn's cwd will be the wingman repo's own root, i.e.
# the one case where Claude Code's automatic CLAUDE.md load pulls in the
# orchestrator's own first-person persona file for a crew session to read
# (issue #69). Repo scope only: global scope's cwd is the workspace root,
# not this repo, even when $WM_REPO is among the discovered repos.
TARGET_IS_WM_REPO=0
[ "$SCOPE" = repo ] && [ "$REPO" = "$WM_REPO" ] && TARGET_IS_WM_REPO=1

# --- resolve the playbook (local override wins) ------------------------------
# A crew type is valid iff a playbook exists for it under $WM_PLAYBOOKS. A bare
# name (e.g. "developer") is searched across every category - role names are
# kept unique across categories, so every existing and shipped type resolves
# unambiguously. A category-qualified name ("software-development/developer")
# is accepted to break a genuine collision. Add
# $WM_PLAYBOOKS/<category>/<type>.md (tracked) or .local.md (gitignored,
# survives pulls) to define a new type.
wm_resolve_playbook "$TYPE"

# A software-development crew type inherently requires a git checkout to do its
# job (worktree, branch, PR) - restore that half of the "software-dev work OR
# confirmed git repo" requirement here, since detecting IS_GIT above only ever
# covers the second half. Global scope is exempt: git-ness there is deliberately
# undecided at spawn time, and a global-scope developer carries its own defensive
# check for the repo it eventually `cd`s into (see playbooks/software-development/developer.md).
CATEGORY="$(basename "$(dirname "$PLAYBOOK")")"
if [ "$SCOPE" = repo ] && [ "$CATEGORY" = software-development ] && [ "$IS_GIT" -eq 0 ]; then
  wm_die "'$TYPE' is a software-development crew type and requires a git checkout; '$REPO' is not one (or is not the repo's root - see the subdirectory rule in docs/plans/2026-07-13-conditional-git-branch-pr-workflow.md)"
fi

# A role's playbook is written against the shared delivery apparatus
# (deliverable shape, an overridable default flow, review feedback over
# wingman's own channel, optional PR shepherding, merge authorization,
# cleanup) rather than carrying its own copy - append _delivery.md to its
# brief the same way _status-contract.md is always appended. Matched on the
# playbook's own bare name (not $TYPE), so a category-qualified spawn (--type
# software-development/developer) still matches. Add a role's name here only
# once its playbook is written to reference the fragment instead of
# duplicating it.
ROLE_NAME="$(basename "$PLAYBOOK")"
case "$ROLE_NAME" in
  *.local.md) ROLE_NAME="${ROLE_NAME%.local.md}" ;;
  *.md)       ROLE_NAME="${ROLE_NAME%.md}" ;;
esac
INCLUDE_PR_DELIVERY=0
case " developer ml-engineer data-engineer " in
  *" $ROLE_NAME "*) INCLUDE_PR_DELIVERY=1 ;;
esac

# --- preflight: workspace-trust gate (issue #16) -----------------------------
# The one-time-per-directory workspace-trust dialog survives
# --permission-mode bypassPermissions and would otherwise freeze the crew
# window the instant it opens, only to be caught later by watch-fleet's
# reactive stall detection. Detect it non-interactively before opening any
# window at all: $REPO is now fully resolved and physically normalized for
# both scopes (global scope's $REPO is the workspace root - exactly the
# directory the launch script `cd`s into - so one check covers both). A git
# worktree carved out of an already-trusted repo needs no separate check (see
# the plan's z15 finding), and this check is mode-independent - the trust
# dialog appears regardless of --permission-mode - so it runs unconditionally,
# not gated on PERM_MODE below. Hard failure: no tmux window, no crew record,
# no worktree path reservation - exactly like the software-development check
# above.
if ! uv run --no-project --quiet "$WM_LIB/claude-gate-check.py" trust-status \
    --config "${WM_CLAUDE_USER_CONFIG:-$HOME/.claude.json}" --repo "$REPO"; then
  wm_die "workspace trust for '$REPO' has not been accepted yet. Run 'claude' there once, interactively, and accept the trust dialog, then retry this spawn."
fi

# Permission posture for the (unattended) crew session. Default bypassPermissions;
# explicit empty (WM_PERMISSION_MODE=) disables it and falls back to prompting.
# Follow-up (out of scope here): rather than blanket bypass, route each individual
# permission decision up to the pilot as a real blocker via a permission-prompt
# hook / MCP tool, so the pilot approves specific actions instead of all-or-nothing.
PERM_MODE="${WM_PERMISSION_MODE-bypassPermissions}"

# --- preflight: Bypass-Permissions mode acceptance (issue #16) ---------------
# A safety net for a spawn that happens to run before bin/doctor ever did:
# doctor is meant to have already cleared this once, machine-wide (the
# common case). Only fires when bypass mode is actually in effect - an
# explicit WM_PERMISSION_MODE= (empty) disables --permission-mode
# bypassPermissions entirely and falls back to interactive per-tool
# prompting, in which case this dialog never appears and
# skipDangerousModePermissionPrompt is irrelevant.
if [ "$PERM_MODE" = bypassPermissions ] && \
   ! uv run --no-project --quiet "$WM_LIB/claude-gate-check.py" bypass-status \
     --settings "${WM_CLAUDE_USER_SETTINGS:-$HOME/.claude/settings.json}"; then
  wm_die "Bypass-Permissions mode has not been accepted yet. Run 'bin/doctor -y', or accept it manually (see bin/doctor's own message), then retry this spawn."
fi

# Model for the crew session, alongside the other harness-specific knobs
# (WM_AGENT, WM_PERMISSION_MODE). An explicit --model wins; else $WM_MODEL if
# set; else no --model flag is passed and the agent CLI's own default applies.
[ -n "$MODEL" ] || MODEL="${WM_MODEL:-}"

# Remote Control visibility, on by default (empty to disable), mirroring
# WM_PERMISSION_MODE's convention exactly so there is only one pattern to learn.
REMOTE_CONTROL="${WM_REMOTE_CONTROL-1}"

# --- derive an id / slug -----------------------------------------------------
slugify() {
  printf '%s' "$1" | tr '[:upper:]' '[:lower:]' \
    | tr -c 'a-z0-9' '-' | sed 's/--*/-/g; s/^-//; s/-$//' | cut -c1-32
}
if [ -z "$ID" ]; then
  # slugify $TYPE too: a category-qualified type ("common/lead") contains a
  # slash, which is otherwise invalid in a tmux window name and unsafe in a
  # generated file/worktree path.
  ID="$(slugify "$OBJECTIVE")-$(slugify "$TYPE")"
fi
# Ensure uniqueness against the current roster.
base="$ID"; n=2
while wm_state crew-get --id "$ID" >/dev/null 2>&1; do
  ID="$base-$n"; n=$((n+1))
done
WINDOW="wm-$ID"

# --- deterministic worktree path (repo scope, git only) ----------------------
# Recorded at spawn and exported to the member so a non-graceful exit (a
# dead/orphaned member) can still be torn down by crew-standdown. Repo scope AND
# a confirmed git repo only: a worktree is meaningless without a git repo to carve
# it from, and global scope cannot predetermine the repo at spawn anyway, so a
# global-scope member self-registers its worktree via `wm-state crew-set
# --worktree` when it creates one.
WORKTREE=""
[ "$SCOPE" = repo ] && [ "$IS_GIT" -eq 1 ] && WORKTREE="$(dirname "$REPO")/$(basename "$REPO")-$ID"

# --- generate the forced session id ------------------------------------------
if wm_have uuidgen; then SID="$(uuidgen | tr '[:upper:]' '[:lower:]')"; else
  SID="$(wm_py -c 'import uuid;print(uuid.uuid4())')"
fi

# --- generate a per-verdict review-signing token (reviewer type only) --------
# issue #135: a random 32-byte token, held only in this member's own process
# environment (WM_REVIEW_TOKEN below) and never written to any file. wm_state
# crew-add derives and stores only the one-way hash commitments of this value
# (never the raw token itself) - see bin/lib/wm-state.py's _apply_review_token.
REVIEW_TOKEN=""
[ "$TYPE" = reviewer ] && REVIEW_TOKEN="$(wm_py -c 'import secrets; print(secrets.token_hex(32))')"

# --- compose the crew member's appended system prompt ------------------------
wm_state init >/dev/null
SYSPROMPT="$WM_HOME/crew/$ID.sysprompt.md"
{
  printf '# Your assignment\n\n'
  if [ "$SCOPE" = global ]; then
    printf 'Crew id: **%s**  |  Type: **%s**  |  Scope: **global project scope**\n\n' "$ID" "$TYPE"
    printf 'You are grounded at the workspace root `%s`, with every discovered repo available. ' "$REPO"
    printf 'This work is not tied to one repo: **determine the target repo(s) yourself** from the objective, and `cd` into a specific repo for any repo-local work (branches, commits, PRs). If it turns out the work belongs to a single repo, just operate there.\n\n'
  else
    printf 'Crew id: **%s**  |  Type: **%s**  |  Repo: `%s`\n\n' "$ID" "$TYPE" "$REPO"
  fi
  if [ "$TARGET_IS_WM_REPO" -eq 1 ]; then
    printf '**About this repo'"'"'s CLAUDE.md:** the file `CLAUDE.md` at this repo'"'"'s root, which your harness just loaded automatically as project context, is written entirely in first person for the **wingman orchestrator** role - the top-level session the pilot starts directly, not this session. Nothing in it is a rule for you. You are a **%s** crew member: your role, permissions, and instructions are the playbook below and the objective above - follow those. Where CLAUDE.md says "you" (e.g. "you never edit playbooks yourself," "never do heavy work yourself"), it describes the orchestrator session'"'"'s own behavior, not a restriction on this one; treat CLAUDE.md only as optional background reading about how wingman is built, useful if it helps your actual task.\n\n' "$TYPE"
  fi
  if [ -n "$INPUT" ]; then
    printf 'Input handoff: read the plan/spec at `%s` and follow it.\n\n' "$INPUT"
  fi
  printf -- '---\n\n'
  cat "$PLAYBOOK"
  if [ "$INCLUDE_PR_DELIVERY" -eq 1 ]; then
    printf '\n\n---\n\n'
    cat "$WM_PLAYBOOKS/_delivery.md"
  fi
  printf '\n\n---\n\n'
  cat "$WM_PLAYBOOKS/_status-contract.md"
} > "$SYSPROMPT"

# --- write the launch script (avoids all in-tmux quoting) --------------------
LAUNCH="$WM_HOME/crew/$ID.launch.sh"
{
  echo '#!/usr/bin/env bash'
  echo "cd $(quote "$REPO") || exit 1"
  echo "export WINGMAN_HOME=$(quote "$WM_HOME")"
  # The current wingman run's id, so this member can tell whether a cached
  # preferences.json answer was written during this same run (still valid) or a
  # stale prior one (must ask again). Empty if wingman wasn't
  # launched via bin/wingman (no run id stamped) - a member then treats the cache
  # as never valid, the same conservative default as a missing/unreadable file.
  echo "export WINGMAN_RUN_ID=$(quote "${WINGMAN_RUN_ID:-}")"
  echo "export WINGMAN_CREW_ID=$(quote "$ID")"
  # The crew type (playbook name), so a hook or the member itself can distinguish
  # an orchestrator role (e.g. lead) from a worker role without re-deriving it.
  echo "export WINGMAN_CREW_TYPE=$(quote "$TYPE")"
  # The full state-engine invocation, run through uv (--no-project so it ignores
  # the target repo's own pyproject). Crew run it unquoted so it word-splits.
  # Built once in bin/lib/common.sh, so a crew session and wingman's own session
  # carry the identical string and the hooks that resolve it cannot drift.
  echo "export WINGMAN_STATE=$(quote "$WINGMAN_STATE")"
  # The wingman bin/ dir, so a crew grounded in another repo can still invoke the
  # crew-level tools it needs by absolute path (e.g. $WINGMAN_BIN/pr-watch).
  echo "export WINGMAN_BIN=$(quote "$WM_BIN")"
  # The deterministic worktree path (repo scope): the developer playbook creates the
  # worktree at exactly this path, so teardown needs only the path. Absent for global
  # scope, whose member self-registers the path after it creates the worktree.
  [ -n "$WORKTREE" ] && echo "export WINGMAN_WORKTREE=$(quote "$WORKTREE")"
  # The three-state git/remote signal (repo scope only): unset (never exported)
  # means "not yet known, detect it yourself" - never the same as false. Global
  # scope leaves both unexported deliberately: git-ness there is undecided at
  # spawn time, since the member picks its own target repo(s) after landing.
  if [ "$SCOPE" = repo ]; then
    echo "export WINGMAN_IS_GIT=$([ "$IS_GIT" -eq 1 ] && echo true || echo false)"
    [ "$IS_GIT" -eq 1 ] && echo "export WINGMAN_HAS_REMOTE=$([ "$HAS_REMOTE" -eq 1 ] && echo true || echo false)"
  fi
  # The raw review-signing token (reviewer type only, issue #135): referenced
  # in the reviewer playbook only as "$WM_REVIEW_TOKEN" (never echoed into a
  # captured tool result), so it never appears anywhere but this one process's
  # own environment - not the roster, not any file, not a conversation
  # transcript.
  [ -n "$REVIEW_TOKEN" ] && echo "export WM_REVIEW_TOKEN=$(quote "$REVIEW_TOKEN")"
  # WM_AGENT and WM_PERMISSION_MODE are the harness-specific lines (swap both for a
  # different harness). WM_AGENT is the agent CLI (default: claude; tests also use
  # it to substitute a stub).
  wm_guard_test_fixture_agent "${WM_AGENT:-claude}"
  printf 'exec %s' "${WM_AGENT:-claude}"
  # Crew run unattended, disposably, and scoped to one repo, so the default
  # bypassPermissions keeps a gated tool call from hanging forever on a prompt no
  # human is there to answer. (It does NOT clear the one-time workspace-trust
  # dialog, which no flag bypasses; the watcher surfaces that instead.) Set
  # WM_PERMISSION_MODE= (empty) to disable and fall back to interactive prompting.
  [ -n "$PERM_MODE" ] && printf ' --permission-mode %s' "$(quote "$PERM_MODE")"
  printf ' --session-id %s' "$(quote "$SID")"
  # The crew's own human-readable slug as the session name, so it shows up
  # legibly in the Claude Code session picker / terminal title instead of an
  # auto-generated one.
  printf ' --name %s' "$(quote "$ID")"
  [ -n "$MODEL" ]  && printf ' --model %s'  "$(quote "$MODEL")"
  [ -n "$EFFORT" ] && printf ' --effort %s' "$(quote "$EFFORT")"
  # Remote-Control-visible by default (WM_REMOTE_CONTROL, mirroring
  # WM_PERMISSION_MODE's on-by-default/empty-to-disable convention): the pilot can
  # reach a crew member from claude.ai/code, not only via tmux attach. The
  # wm-prefixed name matches the tmux window name ($WINDOW), so the member reads
  # identically in both places. Fails soft on non-subscription (API-key) auth -
  # verified empirically: the session starts normally and Remote Control is just
  # quietly unavailable - so defaulting this on is safe everywhere.
  [ -n "$REMOTE_CONTROL" ] && printf ' --remote-control %s' "$(quote "wm-$ID")"
  printf ' --add-dir %s' "$(quote "$WM_HOME")"
  printf ' --add-dir %s' "$(quote "$WM_REPO")"
  # Global scope: add every discovered repo so the member can work across all of
  # them (the cwd is the workspace root, which need not be a git checkout itself).
  if [ "$SCOPE" = global ]; then
    printf '%s\n' "$GLOBAL_REPO_DIRS" | while IFS= read -r _d; do
      [ -n "$_d" ] && printf ' --add-dir %s' "$(quote "$_d")"
    done
  fi
  printf ' --append-system-prompt "$(cat %s)"' "$(quote "$SYSPROMPT")"
  printf '\n'
} > "$LAUNCH"
chmod +x "$LAUNCH"

# --- launch the tmux window --------------------------------------------------
wm_tmux_ensure_session
# The target is session-scoped via the trailing colon. `new-window` takes a
# target-*window*, so a bare "$WM_TMUX_SESSION" is resolved window-first: when
# the caller's current session holds a window of that same name (e.g. the pilot
# runs wingman in a tmux window named "wingman"), tmux binds the target to that
# window's index and fails with "create window failed: index N in use". The
# trailing colon forces session-scope resolution, so tmux inserts at the next
# free index in our session regardless of window names elsewhere. The "="
# prefix (WM_TMUX_TARGET) makes the session part exact-match, so the window
# can only ever land in the crew session wm_tmux_ensure_session just
# guaranteed - never in a prefix-matched neighbour like "wingman-main".
# -PF prints the new window's id (@N); recorded in the roster so stray-window
# adoption can match this exact window, not just its name.
WINDOW_ID="$(wm_tmux new-window -d -PF '#{window_id}' -t "$WM_TMUX_TARGET:" -n "$WINDOW" "bash $(quote "$LAUNCH")")"

# --- record in the roster ----------------------------------------------------
# --parent stamps ownership from the spawning crew's id: empty for wingman (the
# top orchestrator has no $WINGMAN_CREW_ID), the lead's own id when a lead spawns.
# Owner-scoping (surfacing, the watcher, crew-list) all fall out of this field.
ADD_ARGS=(--id "$ID" --type "$TYPE" --objective "$OBJECTIVE" \
  --repo "$REPO" --scope "$SCOPE" --parent "${WINGMAN_CREW_ID:-}" \
  --window "$WINDOW" --window-id "$WINDOW_ID" --session-id "$SID" --worktree "$WORKTREE")
[ "$ALLOW_MERGE" = 1 ] && ADD_ARGS+=(--allow-merge)
[ "$WAIVE_REVIEW_GATE" = 1 ] && ADD_ARGS+=(--waive-review-gate)
[ -n "$REVIEW_TOKEN" ] && ADD_ARGS+=(--review-token "$REVIEW_TOKEN")
# is_git/has_remote mirror the launch-script export above: recorded for repo
# scope only, so the JSON field stays absent (not false) for global scope - the
# same true/false/unset distinction, now on the roster record too. Passed as the
# literal strings "true"/"false" (the crew-add flag is string-shaped so it can be
# typed on a command line); wm-state.py converts to a real JSON boolean.
if [ "$SCOPE" = repo ]; then
  ADD_ARGS+=(--is-git "$([ "$IS_GIT" -eq 1 ] && echo true || echo false)")
  [ "$IS_GIT" -eq 1 ] && ADD_ARGS+=(--has-remote "$([ "$HAS_REMOTE" -eq 1 ] && echo true || echo false)")
fi
# Mirrors the launch-flag conditional above ("$REMOTE_CONTROL" non-empty),
# reading the same variable, so the roster record and the actual launch flag
# can never disagree about whether this member started Remote-Control-visible
# (issue #96).
[ -n "$REMOTE_CONTROL" ] && ADD_ARGS+=(--remote-control)
if ! ADD_ERR="$(wm_state crew-add "${ADD_ARGS[@]}" 2>&1 >/dev/null)"; then
  wm_tmux kill-window -t "$(wm_tmux_win_target "$WINDOW")" 2>/dev/null || true
  wm_die "crew-add failed for '$ID' - window $WINDOW was torn down, nothing to attach to: $ADD_ERR"
fi
# Verify-after-write: confirm the record is actually retrievable, not just that
# crew-add claimed exit 0 (issue #79) - redundant with #93's locking fix by
# design, since a caller here can't tell a genuinely lost write from one that
# merely raced and lost.
if ! wm_state crew-get --id "$ID" >/dev/null 2>&1; then
  wm_tmux kill-window -t "$(wm_tmux_win_target "$WINDOW")" 2>/dev/null || true
  wm_die "crew-add reported success for '$ID' but the record is not readable back - window $WINDOW was torn down"
fi

# --- deliver the opening objective as the first user message -----------------
# A small head start off the window launch; wm_tmux_send_message then waits for the
# TUI to actually be ready before typing and confirms the submit registered, so a
# variable startup no longer leaves the objective unsent in the input box.
sleep "${WM_SPAWN_DELAY:-2}"
OPENING="$OBJECTIVE"
[ -n "$INPUT" ] && OPENING="$OBJECTIVE (input/plan: $INPUT)"
# WM_CLEAR_KEYS="" (issue #157): this window was just created, so there is no
# pre-existing composed text to clear, and unlike every other
# wm_tmux_send_message caller (crew-say/crew-ask/watch-fleet/crew-standdown,
# all aimed at a session that has been up and idle for a while) it can still be
# mid-startup here even after wm_tmux_pane_ready settles stable - a splash
# screen can sit static for a beat before the CLI actually claims raw-mode
# input handling. A real composer already in raw mode absorbs the defensive
# Ctrl-C harmlessly (verified live), but a not-yet-raw-mode terminal would
# still honor the tty's default SIGINT disposition and the keystroke would
# kill the freshly spawned process outright instead of clearing anything -
# skip it here, where it has nothing to do anyway.
WM_CLEAR_KEYS="" wm_tmux_send_message "$(wm_tmux_win_target "$WINDOW")" "$OPENING"
_opening_rc=$?
# A fresh window can be sitting on the one-time Bypass-Permissions/workspace-trust
# gate (the two interactive dialogs no flag can bypass) rather than an idle chat
# prompt; wm_tmux_send_message refuses rather than risk the objective's Enter being
# consumed as an answer to that dialog. This is the same known startup-gate freeze
# the watcher already flags as blocked - non-fatal here, but the objective was NOT
# confirmed delivered (rc 2 = dialog refusal, 3 = unconfirmed submit, 4 = send
# lock contention), so queue it: bin/watch-fleet retries the member's outbox
# each poll once the pane is deliverable, with a manual crew-say as the
# fallback remedy.
if [ "$_opening_rc" -ne 0 ]; then
  mkdir -p "$WM_HOME/outbox/$ID"
  printf '%s\n' "$OPENING" > "$WM_HOME/outbox/$ID/$(date +%s)-$$.msg"
  wm_warn "opening objective NOT confirmed delivered to '$ID' (its pane may be sitting on a permission/trust dialog - see: bin/crew-takeover $ID). It is QUEUED for automatic retry by the watcher; to deliver manually instead: bin/crew-say $ID \"$OPENING\""
fi

if [ "$SCOPE" = global ]; then
  wm_ok "spawned $TYPE crew '$ID' in window $WINDOW (global scope at $(basename "$REPO"), session $SID)"
else
  wm_ok "spawned $TYPE crew '$ID' in window $WINDOW (repo: $(basename "$REPO"), session $SID)"
fi
[ "$ALLOW_MERGE" = 1 ] && wm_ok "'$ID' spawned with merge autonomy for this effort (issue #46)"
[ "$WAIVE_REVIEW_GATE" = 1 ] && wm_ok "'$ID' spawned with the review gate waived for this effort (issue #132)"
[ "$FORCE_DURING_OUTAGE" = 1 ] && wm_ok "'$ID' spawned with --force-during-outage (issue #23)"
[ "$FORCE_DURING_USAGE_LIMIT" = 1 ] && wm_ok "'$ID' spawned with --force-during-usage-limit (issue #24)"
printf 'attach with: tmux attach -t %s \\; select-window -t %s\n' "$WM_TMUX_TARGET" "$(wm_tmux_win_target "$WINDOW")"
echo "$ID"
