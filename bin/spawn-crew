#!/usr/bin/env bash
# spawn-crew - the core recipe: launch one crew member as an independent,
# interactive claude session in its own tmux window, in the target repo.
#
# Usage:
#   spawn-crew --type <spec|build|lead> --repo <path-or-name> \
#              --objective "<what to do>" \
#              [--id <slug>] [--input <plan-or-report-path>] \
#              [--model <alias|id>] [--effort <low|medium|high|xhigh|max>]
#
# Prints the crew id on success. All tmux calls are confined to this file and
# lib/common.sh so a future session backend is a localized change.
# bash-3.2-safe.
set -u
. "$(dirname "$0")/lib/common.sh"

TYPE=""; REPO_ARG=""; OBJECTIVE=""; ID=""; INPUT=""; MODEL=""; EFFORT=""
while [ $# -gt 0 ]; do
  case "$1" in
    --type)      TYPE="$2"; shift 2 ;;
    --repo)      REPO_ARG="$2"; shift 2 ;;
    --objective) OBJECTIVE="$2"; shift 2 ;;
    --id)        ID="$2"; shift 2 ;;
    --input)     INPUT="$2"; shift 2 ;;
    --model)     MODEL="$2"; shift 2 ;;
    --effort)    EFFORT="$2"; shift 2 ;;
    -h|--help)   sed -n '2,12p' "$0"; exit 0 ;;
    *)           wm_die "unknown arg: $1" ;;
  esac
done

[ -n "$TYPE" ] || wm_die "--type is required (spec|build|lead)"
[ -n "$REPO_ARG" ] || wm_die "--repo is required (a path or a discovered project name)"
[ -n "$OBJECTIVE" ] || wm_die "--objective is required"
case "$TYPE" in spec|build|lead) ;; *) wm_die "unknown --type '$TYPE' (spec|build|lead)" ;; esac

# --- resolve the target repo -------------------------------------------------
if [ -d "$REPO_ARG/.git" ] || { [ -d "$REPO_ARG" ] && git -C "$REPO_ARG" rev-parse --git-dir >/dev/null 2>&1; }; then
  REPO="$(cd "$REPO_ARG" && pwd)"
else
  REPO="$("$WM_BIN/discover-projects" "$REPO_ARG")" || exit 1
fi
git -C "$REPO" rev-parse --git-dir >/dev/null 2>&1 || wm_die "'$REPO' is not a git checkout"

# --- resolve the playbook (local override wins) ------------------------------
PLAYBOOK="$WM_REPO/playbooks/$TYPE.md"
[ -f "$WM_REPO/playbooks/$TYPE.local.md" ] && PLAYBOOK="$WM_REPO/playbooks/$TYPE.local.md"
[ -f "$PLAYBOOK" ] || wm_die "no playbook for type '$TYPE' at $PLAYBOOK"

# --- derive an id / slug -----------------------------------------------------
slugify() {
  printf '%s' "$1" | tr '[:upper:]' '[:lower:]' \
    | tr -c 'a-z0-9' '-' | sed 's/--*/-/g; s/^-//; s/-$//' | cut -c1-32
}
if [ -z "$ID" ]; then
  ID="$(slugify "$OBJECTIVE")-$TYPE"
fi
# Ensure uniqueness against the current roster.
base="$ID"; n=2
while wm_state crew-get --id "$ID" >/dev/null 2>&1; do
  ID="$base-$n"; n=$((n+1))
done
WINDOW="wm-$ID"

# --- generate the forced session id ------------------------------------------
if wm_have uuidgen; then SID="$(uuidgen | tr '[:upper:]' '[:lower:]')"; else
  SID="$(wm_py -c 'import uuid;print(uuid.uuid4())')"
fi

# --- compose the crew member's appended system prompt ------------------------
wm_state init >/dev/null
SYSPROMPT="$WM_HOME/crew/$ID.sysprompt.md"
{
  printf '# Your assignment\n\n'
  printf 'Crew id: **%s**  |  Type: **%s**  |  Repo: `%s`\n\n' "$ID" "$TYPE" "$REPO"
  if [ -n "$INPUT" ]; then
    printf 'Input handoff: read the plan/spec at `%s` and follow it.\n\n' "$INPUT"
  fi
  printf -- '---\n\n'
  cat "$PLAYBOOK"
  printf '\n\n---\n\n'
  cat "$WM_REPO/playbooks/_status-contract.md"
} > "$SYSPROMPT"

# --- write the launch script (avoids all in-tmux quoting) --------------------
LAUNCH="$WM_HOME/crew/$ID.launch.sh"
{
  echo '#!/usr/bin/env bash'
  echo "cd $(quote "$REPO") || exit 1"
  echo "export WINGMAN_HOME=$(quote "$WM_HOME")"
  echo "export WINGMAN_CREW_ID=$(quote "$ID")"
  # The full state-engine invocation, run through uv (--no-project so it ignores
  # the target repo's own pyproject). Crew run it unquoted so it word-splits.
  echo "export WINGMAN_STATE=$(quote "$WM_UV $WM_STATE_PY")"
  # WM_CLAUDE lets tests substitute a stub for the real claude binary.
  printf 'exec %s' "${WM_CLAUDE:-claude}"
  printf ' --session-id %s' "$(quote "$SID")"
  [ -n "$MODEL" ]  && printf ' --model %s'  "$(quote "$MODEL")"
  [ -n "$EFFORT" ] && printf ' --effort %s' "$(quote "$EFFORT")"
  printf ' --add-dir %s' "$(quote "$WM_HOME")"
  printf ' --add-dir %s' "$(quote "$WM_REPO")"
  printf ' --append-system-prompt "$(cat %s)"' "$(quote "$SYSPROMPT")"
  printf '\n'
} > "$LAUNCH"
chmod +x "$LAUNCH"

# --- launch the tmux window --------------------------------------------------
wm_tmux_ensure_session
wm_tmux new-window -d -t "$WM_TMUX_SESSION" -n "$WINDOW" "bash $(quote "$LAUNCH")"

# --- record in the roster ----------------------------------------------------
wm_state crew-add --id "$ID" --type "$TYPE" --objective "$OBJECTIVE" \
  --repo "$REPO" --window "$WINDOW" --session-id "$SID" >/dev/null

# --- deliver the opening objective as the first user message -----------------
# Give the interactive session a moment to reach its input prompt, then type.
sleep "${WM_SPAWN_DELAY:-2}"
OPENING="$OBJECTIVE"
[ -n "$INPUT" ] && OPENING="$OBJECTIVE (input/plan: $INPUT)"
wm_tmux send-keys -t "$WM_TMUX_SESSION:$WINDOW" -l "$OPENING"
wm_tmux send-keys -t "$WM_TMUX_SESSION:$WINDOW" Enter

wm_ok "spawned $TYPE crew '$ID' in window $WINDOW (repo: $(basename "$REPO"), session $SID)"
printf 'attach with: tmux attach -t %s \\; select-window -t %s\n' "$WM_TMUX_SESSION" "$WINDOW"
echo "$ID"
