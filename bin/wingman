#!/usr/bin/env bash
# wingman - optional convenience launcher.
# cd into the wingman repo and start claude with the discovered project roots
# added via --add-dir, so wingman's own occasional light cross-project reads
# don't prompt. Discovery and spawning work with or without this launcher.
# bash-3.2-safe.
set -u
. "$(dirname "$0")/lib/common.sh"

# Ensure state home + a fresh-enough project cache exist.
wm_state init >/dev/null
"$WM_BIN/discover-projects" --quiet >/dev/null 2>&1 || true

# A fresh id per wingman run, stamped and exported so every crew member spawned
# during this run (bin/spawn-crew embeds it into the generated launch script,
# alongside WINGMAN_HOME) can tell whether a cached answer in
# pilot-location.json (ask 3, condition B) was written during THIS run or a
# stale prior one. uuidgen if available (matches spawn-crew's own session-id
# generation), else a python uuid fallback - either way just needs to be unique
# per run, not cryptographically meaningful.
if wm_have uuidgen; then WINGMAN_RUN_ID="$(uuidgen | tr '[:upper:]' '[:lower:]')"; else
  WINGMAN_RUN_ID="$(wm_py -c 'import uuid;print(uuid.uuid4())')"
fi
export WINGMAN_RUN_ID

# Register this session's own pane (ask 2, wingman-side): if running inside tmux
# ($TMUX_PANE set - the common case the existing crew tooling already assumes
# elsewhere), record it so bin/watch-fleet can read-only watch it for a dropped
# Remote Control connection and wake wingman the moment it happens, without ever
# injecting keystrokes into this pane (see watch-fleet's self_pane_check). A
# plain terminal or GUI tab with no tmux underneath simply has no pane to
# register; best-effort, never fatal.
[ -n "${TMUX_PANE:-}" ] && printf '%s\n' "$TMUX_PANE" > "$WM_HOME/self-pane" 2>/dev/null

# Collect --add-dir args from the discovered roots.
adddirs=""
while IFS= read -r root; do
  [ -n "$root" ] && adddirs="$adddirs --add-dir $root"
done <<EOF
$("$WM_BIN/discover-projects" --roots 2>/dev/null)
EOF

cd "$WM_REPO" || wm_die "cannot cd into wingman repo: $WM_REPO"
# shellcheck disable=SC2086
exec claude $adddirs "$@"
