#!/usr/bin/env bash
# doctor - dependency preflight for wingman.
# Checks each dependency, prints a platform-aware report, and offers to install
# the missing ones. Run on first launch (CLAUDE.md wires this) and any time.
#
# Exit 0 when all *required* deps are present, 1 otherwise.
# bash-3.2-safe.
set -u
. "$(dirname "$0")/lib/common.sh"

AUTO_YES=0
for arg in "$@"; do
  case "$arg" in
    -y|--yes) AUTO_YES=1 ;;
    -h|--help) echo "usage: doctor [-y]"; exit 0 ;;
  esac
done

MISSING_REQUIRED=0
INSTALL_QUEUE=""   # space-separated brew/apt package names

# check <binary> <required|optional> <pkg> [note]
check() {
  bin="$1"; level="$2"; pkg="$3"; note="${4:-}"
  if wm_have "$bin"; then
    wm_ok "$bin$([ -n "$note" ] && echo " ($note)")"
    return
  fi
  cmd="$(wm_install_cmd "$pkg")"
  if [ "$level" = required ]; then
    wm_err "$bin MISSING (required) ${note:+- $note}"
    MISSING_REQUIRED=1
  else
    wm_warn "$bin missing (optional) ${note:+- $note}"
  fi
  if [ -n "$cmd" ]; then
    printf '    install: %s\n' "$cmd"
    INSTALL_QUEUE="$INSTALL_QUEUE $pkg"
  else
    printf '    install: see your package manager for %s\n' "$pkg"
  fi
}

wm_info "wingman doctor - platform: $(wm_platform)"
echo

# Irreducible core: must already exist, we do not offer to install these.
if wm_have claude; then wm_ok "claude"; else wm_err "claude MISSING - install Claude Code first: https://claude.com/claude-code"; MISSING_REQUIRED=1; fi
if wm_have git;    then wm_ok "git";    else wm_err "git MISSING - install git first"; MISSING_REQUIRED=1; fi

# Core runtime deps doctor can install with consent.
check tmux     required tmux
check uuidgen  required util-linux "session-id generation"

# uv runs the state engine and manages the Python interpreter itself.
if wm_have uv; then
  wm_ok "uv (runs the state engine; manages Python)"
else
  wm_err "uv MISSING (required) - runs the state engine and manages Python"
  MISSING_REQUIRED=1
  case "$(wm_platform)" in
    macos) printf '    install: brew install uv\n'; INSTALL_QUEUE="$INSTALL_QUEUE uv" ;;
    *)     printf '    install: curl -LsSf https://astral.sh/uv/install.sh | sh\n' ;;
  esac
fi

# Optional / nice-to-have. python3 is not required: uv provides an interpreter.
check python3  optional python3 "optional; uv provides the interpreter"
check jq       optional jq "optional; the state engine handles JSON"

# Soft: only flag gh if the ACTIVE developer playbook references it.
dev_playbook="$WM_REPO/playbooks/software-development/developer.md"
[ -f "$WM_REPO/playbooks/software-development/developer.local.md" ] && dev_playbook="$WM_REPO/playbooks/software-development/developer.local.md"
if [ -f "$dev_playbook" ] && grep -q '\bgh\b' "$dev_playbook" 2>/dev/null; then
  check gh optional gh "used by the active developer playbook for PRs (run 'gh auth login')"
fi

# Optional: gitleaks powers bin/lib/artifact-scan.sh, the pre-publish content
# scan gating ask 3a's Artifact-publish path (docs/plans/2026-07-12-remote-
# control-visibility-and-auto-reconnect-design.md). Without it the scan fails
# closed (treats "cannot verify" as "do not publish"), so a crew member can
# still surface deliverables by local path exactly as before this feature -
# missing gitleaks only means Artifact-publishing itself stays unavailable.
check gitleaks optional gitleaks "secret-scanning for the Artifact-publish content-scan gate; without it, that gate always fails closed"

echo
# Offer to install queued packages.
INSTALL_QUEUE="$(echo "$INSTALL_QUEUE" | sed 's/^ *//;s/ *$//')"
if [ -n "$INSTALL_QUEUE" ]; then
  pm=""
  case "$(wm_platform)" in
    macos) wm_have brew && pm="brew install" ;;
    linux)
      if wm_have apt-get; then pm="sudo apt-get install -y"
      elif wm_have dnf; then pm="sudo dnf install -y"
      elif wm_have pacman; then pm="sudo pacman -S --noconfirm"; fi ;;
  esac
  if [ -z "$pm" ]; then
    wm_warn "no known package manager detected; install manually: $INSTALL_QUEUE"
  else
    full="$pm $INSTALL_QUEUE"
    do_it=0
    if [ "$AUTO_YES" = 1 ]; then
      do_it=1
    elif [ -t 0 ]; then
      printf 'Install missing packages now? [%s] (y/N) ' "$full"
      read ans
      case "$ans" in y|Y|yes|YES) do_it=1 ;; esac
    else
      wm_warn "non-interactive; run: $full"
    fi
    if [ "$do_it" = 1 ]; then
      wm_info "running: $full"
      # shellcheck disable=SC2086
      if $full; then wm_ok "install complete"; else wm_err "install failed; run manually: $full"; fi
    fi
  fi
fi

# --- delegation guard hook (issue #17), user scope --------------------------
# Registers hooks/no-direct-edit-guard.sh in user-level Claude Code settings
# (~/.claude/settings.json by default) so it fires for wingman's own top-level
# session and any lead regardless of which repo it launches in - a project-
# level entry never loads for a session whose project root is elsewhere.
# Overridable so tests never touch a real developer machine's dotfile.
GUARD_HOOK="$WM_REPO/hooks/no-direct-edit-guard.sh"
GUARD_SETTINGS="${WM_CLAUDE_USER_SETTINGS:-$HOME/.claude/settings.json}"
if uv run --no-project --quiet "$WM_LIB/install-user-hook.py" \
    --settings "$GUARD_SETTINGS" --hook "$GUARD_HOOK" --check >/dev/null 2>&1; then
  wm_ok "delegation guard hook registered ($GUARD_SETTINGS)"
else
  wm_warn "delegation guard hook (issue #17) not registered in $GUARD_SETTINGS"
  printf '    blocks direct Edit/Write/test-runner calls at wingman'"'"'s top-level\n'
  printf '    session and any lead, machine-wide\n'
  do_it=0
  if [ "$AUTO_YES" = 1 ]; then
    do_it=1
  elif [ -t 0 ]; then
    printf 'Register it now? (y/N) '
    read ans
    case "$ans" in y|Y|yes|YES) do_it=1 ;; esac
  else
    wm_warn "non-interactive; run: uv run --no-project $WM_LIB/install-user-hook.py --settings $GUARD_SETTINGS --hook $GUARD_HOOK"
  fi
  if [ "$do_it" = 1 ]; then
    if uv run --no-project --quiet "$WM_LIB/install-user-hook.py" --settings "$GUARD_SETTINGS" --hook "$GUARD_HOOK"; then
      wm_ok "registered delegation guard hook"
    else
      wm_err "failed to register delegation guard hook"
    fi
  fi
fi

# --- Artifact-publish contract hooks (crew sessions, any repo), user scope --
# hooks/artifact-publish-tracker.sh (PostToolUse + PostToolUseFailure) records
# Artifact publishes/failures and artifact-scan.sh fail-verdicts as markers;
# hooks/artifact-link-guard.sh (PreToolUse) gates a crew member's `crew-set
# --status review|done` on those markers (the status contract's condition B).
# Both must fire inside crew sessions whose project root is some other repo
# entirely, so like the delegation guard they need user-level registration - a
# project-level entry in this repo's settings never loads there. (The
# onboarding-preferences trio is the opposite case: wingman's own top-level
# session only, shipped via this repo's checked-in .claude/settings.json, no
# doctor step at all.)
artifact_hook_specs() {
  cat <<EOF
$WM_REPO/hooks/artifact-publish-tracker.sh PostToolUse Artifact|Bash
$WM_REPO/hooks/artifact-publish-tracker.sh PostToolUseFailure Artifact|Bash
$WM_REPO/hooks/artifact-link-guard.sh PreToolUse Bash
EOF
}
artifact_hooks_missing=0
while read -r _h _e _m; do
  [ -n "$_h" ] || continue
  uv run --no-project --quiet "$WM_LIB/install-user-hook.py" \
      --settings "$GUARD_SETTINGS" --hook "$_h" --event "$_e" --check >/dev/null 2>&1 \
    || artifact_hooks_missing=1
done <<EOF
$(artifact_hook_specs)
EOF
if [ "$artifact_hooks_missing" = 0 ]; then
  wm_ok "Artifact-publish contract hooks registered ($GUARD_SETTINGS)"
else
  wm_warn "Artifact-publish contract hooks not registered in $GUARD_SETTINGS"
  printf '    records Artifact publishes and gates crew deliverable reports on them,\n'
  printf '    for crew sessions in any repo, machine-wide\n'
  do_it=0
  if [ "$AUTO_YES" = 1 ]; then
    do_it=1
  elif [ -t 0 ]; then
    printf 'Register them now? (y/N) '
    read ans
    case "$ans" in y|Y|yes|YES) do_it=1 ;; esac
  else
    wm_warn "non-interactive; re-run bin/doctor -y to register them"
  fi
  if [ "$do_it" = 1 ]; then
    artifact_install_failed=0
    while read -r _h _e _m; do
      [ -n "$_h" ] || continue
      uv run --no-project --quiet "$WM_LIB/install-user-hook.py" \
          --settings "$GUARD_SETTINGS" --hook "$_h" --event "$_e" --matcher "$_m" >/dev/null \
        || artifact_install_failed=1
    done <<EOF
$(artifact_hook_specs)
EOF
    if [ "$artifact_install_failed" = 0 ]; then
      wm_ok "registered Artifact-publish contract hooks"
    else
      wm_err "failed to register Artifact-publish contract hooks"
    fi
  fi
fi

# --- Merge-authorization contract hooks (crew sessions, any repo), user scope
# hooks/no-merge-guard.sh (PreToolUse) denies gh pr merge/gh api merge-endpoint
# calls/a direct push to the default branch from a crew session absent an
# explicit, per-effort allow_merge grant (issue #46); hooks/merge-attribution-
# tracker.sh (PostToolUse) posts a PR comment identifying the crew member
# whenever an authorized merge does succeed, since crew act under the pilot's
# own GitHub credentials and mergedBy/author alone can never distinguish the
# two (issue #50). Both must fire inside crew sessions whose project root is
# some other repo entirely, so like the other crew-facing hooks they need
# user-level registration - a project-level entry in this repo's settings
# never loads there.
merge_hook_specs() {
  cat <<EOF
$WM_REPO/hooks/no-merge-guard.sh PreToolUse Bash
$WM_REPO/hooks/merge-attribution-tracker.sh PostToolUse Bash
EOF
}
merge_hooks_missing=0
while read -r _h _e _m; do
  [ -n "$_h" ] || continue
  uv run --no-project --quiet "$WM_LIB/install-user-hook.py" \
      --settings "$GUARD_SETTINGS" --hook "$_h" --event "$_e" --check >/dev/null 2>&1 \
    || merge_hooks_missing=1
done <<EOF
$(merge_hook_specs)
EOF
if [ "$merge_hooks_missing" = 0 ]; then
  wm_ok "merge-authorization contract hooks registered ($GUARD_SETTINGS)"
else
  wm_warn "merge-authorization contract hooks (issue #46) not registered in $GUARD_SETTINGS"
  printf '    denies crew-session merges by default and attributes any authorized one,\n'
  printf '    for crew sessions in any repo, machine-wide\n'
  do_it=0
  if [ "$AUTO_YES" = 1 ]; then
    do_it=1
  elif [ -t 0 ]; then
    printf 'Register them now? (y/N) '
    read ans
    case "$ans" in y|Y|yes|YES) do_it=1 ;; esac
  else
    wm_warn "non-interactive; re-run bin/doctor -y to register them"
  fi
  if [ "$do_it" = 1 ]; then
    merge_install_failed=0
    while read -r _h _e _m; do
      [ -n "$_h" ] || continue
      uv run --no-project --quiet "$WM_LIB/install-user-hook.py" \
          --settings "$GUARD_SETTINGS" --hook "$_h" --event "$_e" --matcher "$_m" >/dev/null \
        || merge_install_failed=1
    done <<EOF
$(merge_hook_specs)
EOF
    if [ "$merge_install_failed" = 0 ]; then
      wm_ok "registered merge-authorization contract hooks"
    else
      wm_err "failed to register merge-authorization contract hooks"
    fi
  fi
fi

# --- Watcher-protection guard (any session, any repo), user scope -----------
# hooks/no-watcher-kill-guard.sh (PreToolUse) denies a kill/pkill/tmux
# kill-window/tmux kill-session command whose target resolves to a currently
# live bin/watch-fleet cycle (issue #64 / #12: a live watcher's liveness is
# the only channel that lets a wake reach an idle orchestrator, and it has
# been killed by mistake before). Unlike the merge-authorization pair (crew
# sessions only) or the delegation guard (a lead or the wingman repo), there
# is no session type for which killing the watcher is ever legitimate - not
# the human's own top-level session, not a lead, not any other crew member -
# so this is registered unconditionally, with no crew-type gating at all.
WATCHER_KILL_HOOK="$WM_REPO/hooks/no-watcher-kill-guard.sh"
if uv run --no-project --quiet "$WM_LIB/install-user-hook.py" \
    --settings "$GUARD_SETTINGS" --hook "$WATCHER_KILL_HOOK" --event PreToolUse --matcher Bash --check >/dev/null 2>&1; then
  wm_ok "watcher-protection guard hook registered ($GUARD_SETTINGS)"
else
  wm_warn "watcher-protection guard hook (issue #64) not registered in $GUARD_SETTINGS"
  printf '    denies killing a live watch-fleet cycle from any session, machine-wide\n'
  do_it=0
  if [ "$AUTO_YES" = 1 ]; then
    do_it=1
  elif [ -t 0 ]; then
    printf 'Register it now? (y/N) '
    read ans
    case "$ans" in y|Y|yes|YES) do_it=1 ;; esac
  else
    wm_warn "non-interactive; run: uv run --no-project $WM_LIB/install-user-hook.py --settings $GUARD_SETTINGS --hook $WATCHER_KILL_HOOK --matcher Bash"
  fi
  if [ "$do_it" = 1 ]; then
    if uv run --no-project --quiet "$WM_LIB/install-user-hook.py" --settings "$GUARD_SETTINGS" --hook "$WATCHER_KILL_HOOK" --event PreToolUse --matcher Bash; then
      wm_ok "registered watcher-protection guard hook"
    else
      wm_err "failed to register watcher-protection guard hook"
    fi
  fi
fi

echo
if [ "$MISSING_REQUIRED" = 0 ]; then
  wm_ok "all required dependencies present"
  # Make sure the state home exists once we're green.
  wm_state init >/dev/null
  exit 0
else
  wm_err "required dependencies missing - resolve the items above, then re-run: bin/doctor"
  exit 1
fi
