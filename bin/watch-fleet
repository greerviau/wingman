#!/usr/bin/env bash
# watch-fleet - the zero-token supervisor, armed as a harness-tracked background
# task (never a detached daemon). One "cycle" is a single run of this script:
# wingman starts it in the background, it BLOCKS - watching crew status files and
# tmux window liveness, absorbing benign "still working" updates - and only EXITS
# the moment a crew member flips to an attention state (blocked/review/done/died/
# stalled) or freezes on a prompt. Because it is a task the agent harness tracks,
# that exit is the wake: the harness re-invokes wingman, which handles the event
# and arms exactly one fresh cycle. A file on disk cannot rouse an idle session,
# so the exit-of-a-tracked-task is the only reliable wake channel; this script
# therefore never tries to inject keystrokes into wingman's terminal.
#
# The pane backstop covers the failure shapes the status files cannot see: a
# member frozen on an interactive permission/trust prompt (flipped to blocked);
# and a member silently stalled - no pane output, no status update, and an
# execution probe finding nothing running in its pane's process tree. A stall
# candidate always gets one check-in nudge first (a plain message into its pane -
# the API/connectivity-error-specific wording if the pane tail matches that
# signature, a generic "checking in" message otherwise), then a full cooldown
# window of continued silence before wm-state stall-check actually flips it to
# stalled; a member that resumes on its own or in response to the nudge never
# flips at all. This keeps a transient spend-limit episode, network blip, or
# brief Anthropic-side outage from escalating straight to the pilot before the
# member has had a chance to recover unassisted.
#
# Fleet-wide outage detection (#23): wingman's own top-level cycle (owner "")
# also tracks a persisted outage-state machine ($WM_HOME/api-outage-state.json,
# see wm_state outage-update) from the SAME per-member API-error signal plus
# how many members die each poll with an API-error pane tail on record
# (wm_state reconcile's death_cause tagging). Crossing the fleet-wide mass
# threshold (the same thresholds group-attention already applies to a single
# poll's batch) fires an outage-detected event; a quiet period after that
# fires outage-cleared. hooks/api-outage-spawn-guard.sh reads this state to
# pause new bin/spawn-crew calls while active - already-running crew are
# never touched.
#
# Proactive usage-limit-quota detection (#24): the SAME owner-"" cycle also
# aggregates every $WM_HOME/usage/<session-id>.json (written by the
# installed statusLine command, bin/lib/usage-statusline.py, from the
# Claude Code CLI's own rate_limits statusline signal) into a persisted
# usage-quota-approach state machine ($WM_HOME/usage-limit-state.json, see
# wm_state usage-update). Crossing the warn threshold fires
# usage-limit-approaching; the window resetting fires usage-limit-reset.
# hooks/usage-limit-spawn-guard.sh reads this state to pause new
# bin/spawn-crew calls while unresolved (approaching) or while the pilot
# chose to wait (paused) - already-running crew are never touched, and this
# does not checkpoint or park in-flight work (see docs/architecture.md's
# "Fleet-wide usage-limit-quota detection" section for the rationale). Unlike
# #23, this decision needs the pilot's explicit wait-vs-continue answer
# (wm_state usage-decide), so wingman's own
# CLAUDE.md tells it what to do on this fire.
#
# On fire, stdout carries the reason lines plus a directive to report the full
# roster; the wake file carries the new events plus the owner-scoped roster
# snapshot to report from.
#
# Benign wakes are absorbed for free: a crew member merely refreshing its
# "working" summary never appears in `needs-attention`, so the loop keeps blocking
# and no wingman turn is spent. Only an actionable event ends the cycle.
#
# At-least-once delivery: the loop checks `needs-attention` at the TOP of each
# iteration (before sleeping), so if something is already pending the instant a
# fresh cycle is armed, it fires immediately. That covers the gap between one
# cycle firing and wingman arming the next - a second crew member finishing in
# that window is surfaced by the next arm, not lost.
#
# Singleton: a live cycle (pid alive + fresh beacon) makes a second arm print
# `watcher: healthy` and exit without starting a rival loop, so wingman can re-arm
# defensively without spawning duplicates. Read the printed status line - `armed`,
# `healthy`, or a `blocked:/review:/done:/died:/stalled:` reason - as the source
# of truth.
#
# Owner scope: each cycle watches exactly one owner's direct reports. Wingman arms
# its own cycle (--owner "" - it has no $WINGMAN_CREW_ID) and never sees a lead's
# workers; a lead arms its own (--owner <lead-id>, the default from its
# $WINGMAN_CREW_ID) and sees only its crew. The pidfile/beacon/wake are keyed by
# owner so wingman's watcher and each lead's watcher coexist without contending.
#
# Usage:
#   watch-fleet            arm one cycle for the caller's own crew: block until an
#                          actionable event, then exit with the reason. Run as a
#                          harness-tracked background task (e.g. Bash
#                          run_in_background), never bundled onto another command.
#   watch-fleet --owner <id>  watch a specific owner's crew ("" = top level).
#                          Defaults to $WINGMAN_CREW_ID, so wingman and a lead each
#                          arm a bare `watch-fleet` and it self-scopes.
#   watch-fleet --status   report whether a live cycle exists (pid + beacon).
#   watch-fleet --stop      stop the current cycle (manual/testing).
#   watch-fleet --start    deprecated alias for arming; warns, then blocks.
#   watch-fleet --classify [--owner <id>]
#                          classify the just-completed cycle's exit with no
#                          stdin: reads (and consumes) the exit-record this
#                          script itself wrote at its own exit point, or, if
#                          none is present, checks whether a fresh cycle is
#                          already live. Prints exactly one of six outcomes on
#                          stdout - `healthy`, `fire`, `remote-control-dropped`,
#                          `stopped` (bare tokens), or `spurious <count> <hint>` /
#                          `spurious-repeated <count> <hint>` (a consecutive-
#                          failure count and a forensic hint) - and exits 0.
#                          `stopped` means the last cycle ended via a deliberate
#                          `--stop`, not a failure - never auto-re-arm on this
#                          alone. Dispatched before claim-lock acquisition:
#                          never creates the claim lock, never mutates
#                          $PIDFILE/$BEATFILE (it legitimately reads both via
#                          the cycle_live check). Intended caller: the `/watch`
#                          skill, immediately after its armed cycle exits.
# bash-3.2-safe.
set -u
. "$(dirname "$0")/lib/common.sh"

# Immunize the wake loop against SIGURG (signal 16). This script is armed as a
# harness-tracked background task, and its exit is the only channel that wakes an
# idle managing session; a stray SIGURG that reaches it terminates the process
# (exit 144 = 128+16) and silently ends that session's turn. SIGURG's default
# disposition is "ignore", but the background-launch environment can hand the
# process a non-default disposition, and the per-poll subprocess churn (pane
# capture, `ps` scan, the stall probe's blocking child) widens the window for one
# to land fatally. Setting it to SIG_IGN here is unconditional and inherited by
# every child spawned below, so neither the loop nor its probes can be killed by a
# signal that carries no meaning for this tool.
trap '' URG

wm_state init >/dev/null

# --- parse owner scope + mode -----------------------------------------------
# The owner this cycle watches defaults to the caller's own crew id ("" = wingman,
# the top orchestrator). --owner overrides it.
OWNER="${WINGMAN_CREW_ID:-}"
MODE=""
while [ $# -gt 0 ]; do
  case "$1" in
    --owner) OWNER="${2:-}"; shift 2 ;;
    --status|--stop|--start|--classify|arm|__loop) MODE="$1"; shift ;;
    "") shift ;;
    -h|--help) sed -n '2,73p' "$0"; exit 0 ;;
    *) wm_die "unknown arg: $1" ;;
  esac
done

# Key the singleton files by owner so per-owner watchers never contend. Owner ""
# (wingman) keeps the legacy filenames so its references and the Stop hook are
# unchanged; a non-empty owner is sanitized into a filesystem-safe suffix.
if [ -n "$OWNER" ]; then
  _key="$(printf '%s' "$OWNER" | tr -c 'A-Za-z0-9._-' '_')"
  PIDFILE="$WM_HOME/watch-$_key.pid"
  WAKEFILE="$WM_HOME/wake-$_key"
  BEATFILE="$WM_HOME/watch-$_key.beat"
  EXITFILE="$WM_HOME/watch-exit-$_key"
  SPURCOUNTFILE="$WM_HOME/watch-spurious-count-$_key"
else
  PIDFILE="$WM_HOME/watch.pid"
  WAKEFILE="$WM_HOME/wake"
  BEATFILE="$WM_HOME/watch.beat"
  EXITFILE="$WM_HOME/watch-exit"
  SPURCOUNTFILE="$WM_HOME/watch-spurious-count"
fi
# The claim-lock path is needed both by --classify's stale-claim-lock check
# (dispatched before claim-lock acquisition) and by the claim loop itself
# further below, so it is defined once, here, ahead of both.
CLAIMLOCK="$PIDFILE.lock"
# One shared forensic log across every owner (never owner-keyed): each line
# carries its own owner column, so a human reading it after the fact sees the
# whole fleet's history in one place rather than needing to know which
# per-owner file to open.
SPURLOG="$WM_HOME/watch-spurious.log"
spurlog() {
  # timestamp \t owner \t kind \t detail
  printf '%s\t%s\t%s\t%s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "${OWNER:-<top>}" "$1" "$2" >> "$SPURLOG"
}
INTERVAL="${WM_WATCH_INTERVAL:-5}"
# A cycle is "live" iff its recorded pid is alive AND its beacon is fresher than
# this grace window. Touched every loop iteration, so a genuinely blocking watcher
# always looks live and a crashed/killed one goes stale within the grace.
GRACE="${WM_WATCH_GRACE:-30}"
# Silent-stall detection. STALL_IDLE seconds of BOTH pane-output silence AND
# status-file staleness nominates a 'working' member; it is flagged stalled only if
# the execution probe (see wm-state stall-check) then finds no late-started
# descendant process and no CPU activity in its pane's process tree.
STALL_IDLE="${WM_STALL_IDLE:-180}"
STALL_ROOT_GRACE="${WM_STALL_ROOT_GRACE:-30}"
STALL_PROBE_GAP="${WM_STALL_PROBE_GAP:-10}"
STALL_CPU_EPS="${WM_STALL_CPU_EPS:-0.5}"
# Fleet-wide correlated event grouping (wm_state group-attention, #22/#23): a
# batch collapses into one bullet only at or above this count AND this ratio of
# the relevant live population - see group-attention's own docstring for the
# denominator rules. A lone death/stall is always routine, never a "batch".
MASS_MIN_COUNT="${WM_MASS_MIN_COUNT:-2}"
MASS_MIN_RATIO="${WM_MASS_MIN_RATIO:-0.5}"
# API/connectivity-error pane signature (#23): a member showing one of these and
# then going quiet is a likely local network blip or Anthropic-side outage, not a
# broken agent, so its check-in nudge (see #61 below) uses this wording instead of
# the generic one. Purely cosmetic - it changes which nudge message is sent and
# which reason template stall-check uses if the nudge doesn't clear it, never the
# gates or the wait itself.
#
# Deliberately portable ERE (#52): GNU grep's \b word-boundary escape combined
# with a {n} interval is rejected outright by BSD grep -E ("invalid repetition
# count(s)"), which makes grep -qE exit 2 (error) rather than 1 (no-match) -
# silently disabling this whole detector on macOS while spamming stderr every
# cycle. `(^|[^0-9A-Za-z_])...([^0-9A-Za-z_]|$)` emulates \b's actual word/
# non-word transition (word chars are `[A-Za-z0-9_]`, so the neighbor must be
# excluded from that whole class, not just digits - excluding only digits, as
# an earlier version of this fix did, lets identifier-shaped text like
# `abc429def` or `sess_429` spuriously match on every platform, not just BSD)
# using only grouping and anchors (both plain ERE, portable), and `5[0-9][0-9]`
# avoids the `{2}` interval entirely.
# "usage limit reached"/"credit balance too low" (issue #24) are two of the
# CLI's own recognized Anthropic-API-error shapes (confirmed in its embedded
# source string list) that this regex did not previously match verbatim -
# `rate.limit` matches "rate limited" but neither of these two phrases. A
# one-line strengthening of the existing reactive fallback: closing this gap
# means a genuine quota exhaustion, once it trips the mass-correlation path,
# surfaces labeled as a likely "API outage" rather than being missed
# entirely - an accepted, known mislabel (the remedy - pause and wait - is
# correct either way), not a distinct quota-exhaustion classification.
WM_APIERR_RE="${WM_APIERR_RE:-rate.limit|rate_limit|(^|[^0-9A-Za-z_])429([^0-9A-Za-z_]|$)|(^|[^0-9A-Za-z_])5[0-9][0-9] [Ee]rror|overloaded_error|Internal Server Error|ECONNRESET|ETIMEDOUT|ENOTFOUND|[Nn]etwork error|[Cc]onnection error|Connection refused|fetch failed|socket hang up|Service Unavailable|Bad Gateway|Gateway Timeout|usage limit reached|credit balance too low}"
WM_APIERR_TAIL="${WM_APIERR_TAIL:-15}"
# Stall self-heal nudge (#61): every stall-idle, pane-stable candidate - not only
# an api-error match - gets exactly one check-in nudge per stall episode (gated
# on the marker file's existence, never re-sent once it exists), and wm-state
# stall-check will not flip a member to 'stalled' until that marker is at least
# STALL_IDLE seconds old (i.e. the nudge has had a full window to work) - see
# the nudge block below and cmd_stall_check's --nudge-age gate. There is
# deliberately no separate cooldown constant here: a second knob governing only
# the resend decision let the shell's resend gate and stall-check's flip gate
# drift apart (#101), so the wait-after-nudge is driven by STALL_IDLE alone.

# Persisted fleet-wide outage-state machine (#23, item 0): active -> clear
# requires this many quiet seconds (zero fresh signal) after the last poll
# that saw one. Defaults to 3 poll intervals - comfortably past one flaky
# poll, matching the API-error nudge cooldown's own "several polls" order of
# magnitude. See wm_state outage-update for the full state machine; this
# value is passed straight through to it as --quiet-seconds.
WM_OUTAGE_QUIET="${WM_OUTAGE_QUIET:-$(( INTERVAL * 3 ))}"

# Proactive usage-limit-quota detection (#24). A window's used_percentage
# crossing this threshold (default 80%) is "approaching" and triggers the
# pause-and-ask flow - see wm_state usage-update. A $WM_HOME/usage/*.json
# reading older than this many seconds is no longer treated as a live
# source (the session that wrote it hasn't produced a fresh statusline tick
# in the last few polls); this is deliberately independent of, and stricter
# than, the resets_at-in-the-future check applied in the same aggregation
# pass - see wm_state usage-update's own docstring for why a single
# staleness bound cannot substitute for both.
WM_USAGE_WARN_THRESHOLD="${WM_USAGE_WARN_THRESHOLD:-80}"
WM_USAGE_STALE_SECS="${WM_USAGE_STALE_SECS:-900}"

# Remote Control disconnect signature (design: docs/plans/2026-07-12-remote-
# control-visibility-and-auto-reconnect-design.md, ask 2): the CLI's own
# disconnect banner, confirmed exact substrings it emits once its bounded
# reconnect budget is exhausted. Crew-side, a settled sighting gets an automatic
# `/remote-control` retry (the existing wm_tmux_send_message primitive, aimed at
# a pane it already has a target for); wingman-side (its own pane, registered at
# startup in $WM_HOME/self-pane), it is detect-only - never injected into - and
# instead fires the ordinary wake so wingman's own next turn tells the pilot.
WM_RC_DROPPED_RE="${WM_RC_DROPPED_RE:-Remote Control disconnected|Transport closed|Transport recovery exhausted}"
WM_RC_DROPPED_TAIL="${WM_RC_DROPPED_TAIL:-15}"
# At most one /remote-control retry per this many seconds per crew member, so a
# connection that will not recover from a slash command alone (e.g. the account
# itself lost its subscription) is not retried every single cycle.
RC_DROPPED_COOLDOWN="${WM_RC_DROPPED_COOLDOWN:-180}"

# Deliberately not given prompt_freeze_check's full UI-shape/adjacency precision:
# there is no equivalent stable "shape" for an error banner the way a numbered-
# options dialog has one, and this check does not need it. Its match never
# mutates state by itself - it only decides whether to attempt a nudge (cheap and
# reversible even if wrong) and which reason stall-check uses if and only if
# stall-check's own independently-gated flip to stalled was going to happen
# anyway. Reads $PANE_TEXT, set for this poll by wm_pane_snapshot.
api_error_check() {
  printf '%s\n' "$PANE_TEXT" | tail -n "$WM_APIERR_TAIL" | grep -qE "$WM_APIERR_RE"
}

# True iff this poll's pane capture (reads $PANE_TEXT, set by wm_pane_snapshot
# like the checks above) carries the Remote Control disconnect signature in its
# tail. Callers additionally require $PANE_STABLE (two identical consecutive
# polls) before acting on a hit - the same "one more poll before acting" rule
# prompt_freeze_check and the API-error nudge both use - so a banner merely
# scrolling transiently through a member's own transcript (e.g. while it reads
# or greps this very detector's strings, which this repo's own source now
# contains) is never mistaken for a live drop: real disconnect banners persist
# on screen, static, until something acts on them.
remote_control_dropped_check() {
  printf '%s\n' "$PANE_TEXT" | tail -n "$WM_RC_DROPPED_TAIL" | grep -qE "$WM_RC_DROPPED_RE"
}

# Wingman's own Remote Control disconnect: read-only detection, never injection.
# `bin/watch-fleet` has always deliberately never sent keystrokes into wingman's
# own pane (see the file header): the only way to act on the disconnect is to
# type `/remote-control` into the very pane wingman's own turn is running in,
# which cannot be done reliably from outside while that turn is mid-render of
# the tool call doing the sending. So this half of ask 2 detects and wakes only;
# the pilot supplies the one keystroke.
#
# Scoped to the owner "" cycle only (wingman's own watcher; a lead's cycle has no
# such pane to watch). $WM_HOME/self-pane is written once at wingman startup
# (bin/wingman, best-effort, only if $TMUX_PANE was set) and names a tmux pane
# id/target directly, independent of $WM_TMUX_SESSION - wingman's own session
# need not run inside the crew tmux session at all.
#
# Fires (returns 0) at most once per distinct banner: a hash of the last banner
# text that already fired is kept in $WM_HOME/self-pane.fired, so an unresolved,
# unchanging banner is surfaced once rather than re-waking wingman every cycle
# until the pilot acts; a new, different disconnect (different hash) fires again.
self_pane_check() {
  [ -z "$OWNER" ] || return 1
  [ -f "$WM_HOME/self-pane" ] || return 1
  _sp_target="$(cat "$WM_HOME/self-pane" 2>/dev/null)"
  [ -n "$_sp_target" ] || return 1
  _sp_text="$(wm_tmux_pane_text "$_sp_target")"
  [ -n "$_sp_text" ] || return 1
  _sp_hash="$(printf '%s' "$_sp_text" | cksum)"
  _sp_hashfile="$WM_HOME/self-pane.hash"
  _sp_prev="$(cat "$_sp_hashfile" 2>/dev/null)"
  printf '%s\n' "$_sp_hash" > "$_sp_hashfile"
  [ -n "$_sp_prev" ] && [ "$_sp_hash" = "$_sp_prev" ] || return 1   # not yet settled
  printf '%s\n' "$_sp_text" | tail -n "$WM_RC_DROPPED_TAIL" | grep -qE "$WM_RC_DROPPED_RE" || return 1
  _sp_firedfile="$WM_HOME/self-pane.fired"
  [ "$(cat "$_sp_firedfile" 2>/dev/null)" != "$_sp_hash" ] || return 1   # already fired for this exact banner
  printf '%s\n' "$_sp_hash" > "$_sp_firedfile"
  return 0
}

beat_age() {
  [ -f "$BEATFILE" ] || { echo 999999; return; }
  m="$(wm_py -c 'import os,sys;print(int(os.path.getmtime(sys.argv[1])))' "$BEATFILE" 2>/dev/null)" || { echo 999999; return; }
  echo $(( $(date +%s) - m ))
}

# A live cycle exists iff the pidfile names a live process and its beacon is fresh.
cycle_live() {
  [ -f "$PIDFILE" ] || return 1
  pid="$(cat "$PIDFILE" 2>/dev/null)"
  [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null || return 1
  [ "$(beat_age)" -lt "$GRACE" ]
}

case "$MODE" in
  --classify)
    # Dispatched here, alongside --status/--stop/--start, deliberately BEFORE
    # claim-lock acquisition below: this call must never mkdir "$CLAIMLOCK",
    # never mutate $PIDFILE/$BEATFILE (cycle_live legitimately reads both),
    # and never enter the blocking loop. Order, exactly as verified correct
    # through seven review rounds: (1) exit-record present - trust it and
    # stop; (2) else cycle_live - a live cycle always means healthy,
    # regardless of any leaked lock coexisting with it; only within the
    # "no cycle live" branch: (3) a leaked claim-lock; (4) the exhaustive
    # pidfile-residue hints. Checking cycle_live before the lock is what
    # keeps a stale, unrelated leaked lock from being misclassified as a
    # live cycle's own failure.
    if [ -f "$EXITFILE" ]; then
      _outcome="$(cat "$EXITFILE" 2>/dev/null)"
      rm -f "$EXITFILE"
      # Rule 2: any non-spurious classify outcome resets the consecutive
      # failure count. All three count-file mutation rules live here, inside
      # --classify, and nowhere else in this script (see the claim-time
      # comment below for why a claim-time reset would silently revert the
      # fix this budget exists to provide).
      printf '0\n' > "$SPURCOUNTFILE"
      printf '%s\n' "$_outcome"
      exit 0
    fi
    if cycle_live; then
      printf '0\n' > "$SPURCOUNTFILE"
      printf 'healthy\n'
      exit 0
    fi
    # No record, no live cycle: genuinely spurious. Determine the forensic
    # hint - checked first, before the pidfile-residue branches, because it is
    # the one hint that is actually about the arm whose death is being
    # classified (a leaked lock blocking every subsequent arm attempt),
    # rather than about residue left behind by an entirely different, earlier
    # cycle. A lock left by a kill landing inside the sub-second claim window
    # (below) is the mechanism; a cycle already past that window and into the
    # blocking loop has already released the lock and cannot leak it this way.
    if [ -d "$CLAIMLOCK" ]; then
      _hint="stale-claim-lock"
    elif [ ! -f "$PIDFILE" ]; then
      _hint="clean-exit-or-sigterm"
    else
      _dead_pid="$(cat "$PIDFILE" 2>/dev/null)"
      if [ -n "$_dead_pid" ] && ! kill -0 "$_dead_pid" 2>/dev/null; then
        # A SIGKILL cannot run the INT TERM trap that removes $PIDFILE, so a
        # survived pidfile naming a dead pid is diagnostic of exactly that.
        _hint="sigkill-suspected"
      else
        # pidfile present, pid alive, beacon stale (cycle_live already ruled
        # out "and beacon fresh") - a wedged process, not a clean death.
        _hint="hung-or-stale-pidfile"
      fi
    fi
    # Pure consecutive count, no wall-clock term anywhere in the trip
    # condition (five review rounds of timing-dependent budgets each found
    # broken in a new way is why this one measures nothing but the sequence
    # of outcomes). A missing or unreadable count file reads as 0 under set
    # -u: the command substitution itself never errors on a missing file (cat
    # fails silently into an empty string), and the case below normalizes
    # both "empty" and "anything non-numeric" to 0 before the arithmetic
    # expansion ever runs, so $((...)) always sees an assigned value.
    _count="$(cat "$SPURCOUNTFILE" 2>/dev/null)"
    case "$_count" in ''|*[!0-9]*) _count=0 ;; esac
    _count=$((_count + 1))
    _budget="${WM_SPURIOUS_BUDGET_COUNT:-3}"
    if [ "$_count" -ge "$_budget" ]; then
      # Rule 3: the trip consumes the budget - reset in the same call that
      # reports it, so a lone stray death long after a genuine recovery is
      # once again absorbed as ordinary `spurious`, not an immediate re-trip.
      spurlog spurious-repeated "$_hint"
      printf '0\n' > "$SPURCOUNTFILE"
      printf 'spurious-repeated %s %s\n' "$_count" "$_hint"
    else
      spurlog spurious "$_hint"
      printf '%s\n' "$_count" > "$SPURCOUNTFILE"
      printf 'spurious %s %s\n' "$_count" "$_hint"
    fi
    exit 0
    ;;
  --status)
    # The documented, scriptable liveness check: exit 0 iff a cycle is live, 1
    # otherwise, so a caller can test `bin/watch-fleet --status >/dev/null 2>&1`
    # without parsing text.
    if cycle_live; then wm_ok "watch-fleet cycle live (pid $(cat "$PIDFILE"), beacon $(beat_age)s)"; exit 0
    else wm_info "no live watch-fleet cycle"; exit 1; fi
    ;;
  --stop)
    if [ -f "$PIDFILE" ]; then
      pid="$(cat "$PIDFILE" 2>/dev/null)"
      printf 'stopped\n' > "$EXITFILE"
      [ -n "$pid" ] && kill "$pid" 2>/dev/null
      rm -f "$PIDFILE"
      wm_ok "watch-fleet stopped"
    else
      printf 'stopped\n' > "$EXITFILE"
      wm_info "no watch-fleet cycle to stop"
    fi
    exit 0 ;;
  --start)
    wm_warn "watch-fleet --start is deprecated: arm 'bin/watch-fleet' as a harness-tracked background task instead. Blocking now."
    ;;
  *) : ;;   # arm/__loop/"" fall through to arm
esac

# --- atomic check-then-claim -------------------------------------------------
# mkdir is documented atomic on every POSIX filesystem (no flock(1) dependency,
# which macOS does not ship), so the check-then-claim below is wrapped in a
# short-lived lock directory: two `watch-fleet` invocations racing in the same
# instant would otherwise both observe no live cycle and both write $PIDFILE,
# the second silently clobbering the first and producing two competing
# blocking loops. The lock is held only across the check+claim (well under a
# second), never across the blocking loop itself, so it adds no contention for
# the common case (one arm at a time). A stuck concurrent arm is bounded at 5s
# rather than hanging forever; a stale lock directory left by a killed process
# is reclaimed automatically by this same invocation once that 5s budget is
# exhausted - but only once the directory is confirmed both old enough and
# provably ownerless (see below). wm_die is reserved for a holder that is
# still genuinely live, too recent to trust as abandoned, or contended again
# within this same invocation.
#
# A `mkdir` "success" is verified, not trusted outright: two near-simultaneous
# claimants have been observed to both see their own `mkdir` report success for
# the identical path (surfaced empirically under this project's own test
# environment - not expected on a well-behaved POSIX filesystem, but cheap to
# defend against regardless of platform). The verification relies on a strictly
# weaker guarantee than `mkdir` atomicity: ordinary sequential writes to one
# small regular file have a well-defined last-writer-wins outcome. Every
# claimant that gets past `mkdir` stamps its own pid into the lock dir, waits
# briefly for any true-concurrent claimant to do the same, then re-reads the
# file - only the single last writer sees its own pid reflected back, so a
# mismatch is treated exactly like a failed `mkdir` (back off and retry).
# ($CLAIMLOCK itself is defined earlier, alongside $PIDFILE, so --classify's
# stale-claim-lock check above can read it without duplicating the path.)
# The lock dir will hold an `owner` file (the verification stamp below), so
# releasing it is always rm -f the file, then rmdir the now-empty dir - a bare
# rmdir would fail (ENOTEMPTY) and leak the lock permanently.
release_claim() { rm -f "$CLAIMLOCK/owner" 2>/dev/null; rmdir "$CLAIMLOCK" 2>/dev/null; }
# CLAIM_STALE_AGE must stay comfortably under the 50-try/0.1s retry budget -
# not equal to it - to absorb whole-second mtime-vs-now truncation while still
# requiring a directory to be many multiples of the sub-second legitimate-
# claim window old before it is even considered for reclaim. (The budget's own
# real floor is 4.9s, not 5.0s: the sleep sits after the increment-and-check,
# so the 50th failed attempt's own sleep never runs before the check fires -
# only 49 sleeps have actually elapsed by then.)
# CLAIM_HARD_STALE_AGE is a second, independent backstop: a directory old
# enough to cross it is reclaimed regardless of what its owner pid looks like,
# closing the case where that pid has been reused by an unrelated process (or
# is simply corrupt). Both are env-overridable so tests can exercise the hard
# override without a real 60-second wait.
CLAIM_STALE_AGE="${WM_CLAIM_STALE_AGE:-4}"
CLAIM_HARD_STALE_AGE="${WM_CLAIM_HARD_STALE_AGE:-60}"
# An overall wall-clock deadline, independent of _claim_reclaimed, bounds the
# "directory vanished/unreadable" retry branches below - those reset the
# 50-try counter on every hit, which is otherwise unbounded against a
# (near-impossible in practice) pathological churn case.
_claim_start="$(date +%s)"
_claim_deadline=30
_claim_tries=0
_claim_reclaimed=0
while :; do
  if mkdir "$CLAIMLOCK" 2>/dev/null; then
    # Registered the instant mkdir succeeds, before the verification below can
    # fail - so this process's own dir is always reclaimed on exit, even if it
    # turns out to have lost the internal write race (never a permanent wedge
    # with no one left to clean it up).
    trap release_claim EXIT
    echo "$$" > "$CLAIMLOCK/owner" 2>/dev/null
    sleep 0.1
    [ "$(cat "$CLAIMLOCK/owner" 2>/dev/null)" = "$$" ] && break
    trap - EXIT   # lost the internal race; the presumed winner's own trap cleans up
  fi
  _claim_tries=$((_claim_tries+1))
  if [ "$_claim_tries" -ge 50 ]; then
    # Re-stat the lock fresh, right now - never act on pid/age information read
    # on an earlier failed attempt (that's exactly the clobber bug this fix
    # closes: acting on stale information about a path can delete a different,
    # live claimant that has since taken over the same path).
    if [ ! -d "$CLAIMLOCK" ]; then
      # Already gone - released or reclaimed by someone else since our last
      # failed mkdir. Nothing to clean up; just retry the mkdir, unless we've
      # been churning on this for so long that something else is clearly wrong.
      [ $(( $(date +%s) - _claim_start )) -ge "$_claim_deadline" ] \
        && wm_die "watcher: could not acquire the claim lock after ${_claim_deadline}s of repeated churn - see $CLAIMLOCK"
      _claim_tries=0
      continue
    fi
    _lock_mtime="$(wm_py -c 'import os,sys;print(int(os.path.getmtime(sys.argv[1])))' "$CLAIMLOCK" 2>/dev/null)"
    if [ -z "$_lock_mtime" ]; then
      # The directory existed a moment ago (the -d check above) but vanished,
      # or became unreadable, before the stat completed - the same benign
      # "someone else already cleaned this up" case as the branch just above,
      # not a reason to fall through to wm_die.
      [ $(( $(date +%s) - _claim_start )) -ge "$_claim_deadline" ] \
        && wm_die "watcher: could not acquire the claim lock after ${_claim_deadline}s of repeated churn - see $CLAIMLOCK"
      _claim_tries=0
      continue
    fi
    _lock_age=$(( $(date +%s) - _lock_mtime ))
    # A directory younger than CLAIM_STALE_AGE cannot be the long-dead lock
    # this fix targets - it is indistinguishable from a legitimate claimant
    # that arrived only moments ago (possibly the very claimant that just
    # replaced a directory we saw fail earlier). Never reclaim on pid liveness
    # alone; fall through to the unchanged wm_die below instead, exactly as
    # before this fix existed.
    if [ "$_lock_age" -ge "$CLAIM_STALE_AGE" ]; then
      _owner_raw="$(cat "$CLAIMLOCK/owner" 2>/dev/null)"
      case "$_owner_raw" in
        # Empty (owner file missing, or never written before its claimant
        # died), or not a plain positive integer (a corrupt stamp, or a value
        # like "-1" that `kill -0` would misread as a process-group target) -
        # both are treated as an unreadable/dead owner, never passed to
        # `kill -0` as-is.
        ''|*[!0-9]*) _owner_dead=1 ;;
        *) if kill -0 "$_owner_raw" 2>/dev/null; then _owner_dead=0; else _owner_dead=1; fi ;;
      esac
      if [ "$_claim_reclaimed" -eq 0 ] \
        && { [ "$_owner_dead" -eq 1 ] || [ "$_lock_age" -ge "$CLAIM_HARD_STALE_AGE" ]; }; then
        wm_warn "watcher: clearing a stale claim lock at $CLAIMLOCK (age ${_lock_age}s, owner pid ${_owner_raw:-unknown})"
        rm -f "$CLAIMLOCK/owner" 2>/dev/null
        rmdir "$CLAIMLOCK" 2>/dev/null
        _claim_reclaimed=1
        _claim_tries=0
        continue
      fi
    fi
    wm_die "watcher: could not acquire the claim lock after 5s (a concurrent arm may be stuck) - see $CLAIMLOCK"
  fi
  sleep 0.1
done

# --- singleton guard --------------------------------------------------------
# If a genuinely live cycle already holds the lock, do not start a rival loop.
# The reworded line leads with "already armed" (mirroring what the caller just
# attempted) and states explicitly that the pid is never a kill target - a fresh
# arm reporting a bare "healthy pid=N" is what got misread as something to stop
# in the incident this closes. The `watcher: healthy` token prefix is unchanged
# so CLAUDE.md's documented arm-status parsing contract still holds.
if cycle_live; then
  wm_ok "watcher: already armed and healthy - one cycle is live (pid $(cat "$PIDFILE"), beacon $(beat_age)s ago). Nothing to do; this pid is the EXISTING watcher, never a target to stop or kill."
  # Non-clobbering: a `fire`/`remote-control-dropped` record from the live
  # cycle this redundant arm just raced against outranks a `healthy` write -
  # --classify's own cycle_live check already derives `healthy` independently
  # from "record absent + a cycle is live", so skipping this write when a
  # record already exists costs nothing and protects the one write that
  # cannot be reconstructed after the fact.
  [ -f "$EXITFILE" ] || printf 'healthy\n' > "$EXITFILE"
  release_claim
  exit 0
fi

# --- claim the cycle --------------------------------------------------------
echo $$ > "$PIDFILE"
# Loud, not silent: the only way a record can still be present at a fresh
# claim is that a wake was never classified - i.e. the record is the last
# remaining trace of an event `fire()` already acked. Append it to the
# forensic log before clearing it, so a lost wake leaves evidence rather than
# vanishing without a trace. This code path never touches
# $SPURCOUNTFILE - the count file's only three writers are inside
# --classify (see the comments there); a claim-time reset would silently
# revert the whole fix for any failure that claims successfully before dying.
if [ -f "$EXITFILE" ]; then
  spurlog dropped-wake "$(cat "$EXITFILE" 2>/dev/null)"
  rm -f "$EXITFILE"
fi
: > "$BEATFILE" || true
release_claim
trap 'rm -f "$PIDFILE"; exit 0' INT TERM
wm_ok "watcher: armed pid=$$ (interval ${INTERVAL}s)"

# The prompt-shape detector (prompt_shape_in) and its WM_PERM_PROMPT_RE/
# WM_PERM_OPTION_RE/WM_PERM_MARK_RE/WM_PERM_MIN_OPTS/WM_PERM_TAIL/WM_PERM_ADJ/
# WM_PERM_LEAD_RE config live in lib/common.sh (shared with wm_tmux_send_message,
# which uses the same detector before typing/submitting into a target pane).
#
# Negative-liveness grace: a member whose status file self-reported more recently
# than this is too fresh to be frozen, so the blocked-flip is vetoed. Defaults to
# two poll intervals. The veto applies ONLY once a member has genuinely
# self-reported since spawn (status.updated has advanced past the immutable
# spawned_at stamp), so a member frozen on the one-time startup gate - which never
# runs crew-set, leaving status.updated at the spawn stamp - is never vetoed.
WM_PERM_LIVENESS_GRACE="${WM_PERM_LIVENESS_GRACE:-$(( INTERVAL * 2 ))}"

# Negative-liveness veto: a genuinely frozen session cannot run crew-set, so its
# status file goes stale. Returns 0 (VETO the blocked flip) iff the member has
# genuinely self-reported since spawn (its status.updated has advanced past the
# immutable spawned_at stamp) AND that self-report is fresher than
# WM_PERM_LIVENESS_GRACE - too recent to be frozen. A member still frozen on the
# one-time startup gate never ran crew-set, so status.updated equals spawned_at and
# the veto does not apply (N2): the startup-gate freeze fires normally. This is a
# veto, not a detector - a legitimately busy member may not self-report for many
# minutes, so freshness alone cannot flag, but its recency can safely acquit.
liveness_veto() {
  _lv_age="$(wm_py -c '
import json, os, sys, datetime
cid = sys.argv[1]
home = os.path.expanduser(os.environ.get("WINGMAN_HOME", "~/.wingman"))
def rj(p):
    try:
        with open(p) as f:
            return json.load(f)
    except Exception:
        return None
live = rj(os.path.join(home, "crew", cid + ".json")) or {}
roster = rj(os.path.join(home, "crew.json")) or []
spawned_at = None
for r in roster:
    if isinstance(r, dict) and r.get("id") == cid:
        spawned_at = r.get("spawned_at")
        break
upd = live.get("updated")
# Not yet self-reported since spawn (still the spawn stamp, or unknown): no veto.
if not upd or spawned_at is None or upd == spawned_at:
    print(999999); sys.exit(0)
try:
    t = datetime.datetime.strptime(upd, "%Y-%m-%dT%H:%M:%S.%fZ").replace(tzinfo=datetime.timezone.utc)
except Exception:
    print(999999); sys.exit(0)
print(int((datetime.datetime.now(datetime.timezone.utc) - t).total_seconds()))
' "$1" 2>/dev/null)"
  [ -n "$_lv_age" ] || return 1
  [ "$_lv_age" -lt "$WM_PERM_LIVENESS_GRACE" ]
}

# True iff a member's pane is frozen on an interactive prompt. Cumulative
# conditions, each of which alone stops the transcript-content false positive
# (a session that reads, writes, tests, or investigates this detector shows the
# signature strings in its own pane while healthily working):
#   1. the prompt UI shape - question phrase with an options line adjacent -
#      appears within the last WM_PERM_TAIL lines, where a dialog renders;
#   2. the full pane text is byte-identical to the previous poll's capture - a
#      frozen dialog is static (costs one extra INTERVAL of latency on a real
#      freeze). Note a *parked* healthy pane is also static (the §3.2 shape),
#      which is why the adjacency in condition 1 must carry precision there.
# Also sets PFC_SHAPE=1 when condition 1 held regardless of stability, so the
# caller can hold the stall check off a prompt-shaped pane that is one INTERVAL
# away from a definitive diagnosis. Reads $PANE_TEXT/$PANE_STABLE, which the
# caller must set for this poll via wm_pane_snapshot before calling this (shared
# with the API-error check, so the pane is captured and hashed once per member
# per poll, not twice).
prompt_freeze_check() {
  PFC_SHAPE=0
  # Scans for either dialog shape in one pass (#23/#30): the ordinary
  # permission/trust/Bypass set, or the resume-from-summary menu - see
  # WM_RESUME_PROMPT_RE's own docstring in lib/common.sh for why this is a
  # second, distinctly-worded regex rather than folded permanently into
  # WM_PERM_PROMPT_RE's own default.
  prompt_shape_in "$(printf '%s\n' "$PANE_TEXT" | tail -n "$WM_PERM_TAIL")" \
    "${WM_PERM_PROMPT_RE}|${WM_RESUME_PROMPT_RE}" || return 1
  PFC_SHAPE=1
  [ "$PANE_STABLE" = 1 ]
}

# Fire the wake: the two channels carry distinct roles. Stdout is the terse
# trigger - the machine reason lines (one per member, "<status>: <id> <note>")
# plus an explicit directive to report the full roster. The wake file is the
# payload to report from - the new events plus the full roster snapshot for this
# cycle's owner scope, written at fire time so it is current.
#
# needs-attention emits tab-separated "id status updated note"; the `updated`
# column is the per-event version stamp we ack below.
fire() {
  _attention="$1"
  # Collapse a fleet-wide correlated batch (mass death, correlated API outage)
  # into one synthetic row for the two DISPLAY loops only (#22/#23, §3.3). This
  # is a pure, stateless filter - it never mutates any status file - so the ack
  # loop below deliberately keeps iterating $_attention (the real ids and their
  # real `updated` stamps), never $_grouped (whose synthetic ids ack nothing).
  _grouped="$(printf '%s\n' "$_attention" | wm_state group-attention \
    --owner "$OWNER" --mass-min-count "$MASS_MIN_COUNT" --mass-min-ratio "$MASS_MIN_RATIO" 2>/dev/null)"
  {
    echo "# Crew need your attention"
    echo
    echo "## New events"
    echo
    printf '%s\n' "$_grouped" | while IFS=$'\t' read -r id st upd note; do
      [ -n "$id" ] && printf -- '- **%s** [%s] %s\n' "$id" "$st" "$note"
    done
    echo
    echo "## Full roster (this owner's scope)"
    echo
    wm_state crew-list --owner "$OWNER" 2>/dev/null
  } > "$WAKEFILE"
  printf '%s\n' "$_grouped" | while IFS=$'\t' read -r id st upd note; do
    [ -n "$id" ] && printf '%s: %s %s\n' "$st" "$id" "$note"
  done
  printf -- '--\n'
  printf 'The lines above are state-change deltas, not the full picture.\n'
  printf 'Read %s for the full roster (or run bin/crew-list), then report a compact\n' "$WAKEFILE"
  printf 'roster status to the pilot: who is on what, what is blocked, what is stalled,\n'
  printf 'what is ready for review. Then arm one fresh watch-fleet cycle before you stop.\n'
  # Firing IS the delivery, so ack each surfaced (id, updated). That suppresses
  # this exact event on subsequent arms while preserving gap-safety: a different
  # crew - or this crew with a new status (new updated) - is not acked and still
  # surfaces on the next arm's top-of-loop check. Acks the REAL ids from
  # $_attention, never the synthetic $_grouped rows (see the comment above).
  printf '%s\n' "$_attention" | while IFS=$'\t' read -r id st upd note; do
    [ -n "$id" ] && wm_state ack --id "$id" --updated "$upd" >/dev/null 2>&1
  done
  # Unconditional: the highest-priority writer. A `fire` record is the only
  # trace of an event that is already acked above - it must never lose to a
  # racing `healthy` write from a redundant arm evaluating the singleton guard
  # in the narrow window before this process's own $PIDFILE removal below.
  printf 'fire\n' > "$EXITFILE"
  rm -f "$PIDFILE"
  exit 0
}

# --- the blocking loop ------------------------------------------------------
while :; do
  : > "$BEATFILE" || true   # liveness beacon for the singleton guard + Stop hook

  # Fleet-wide outage-state signal accumulators (#23, item 0), reset every
  # iteration regardless of owner scope or tmux-session liveness: only
  # mutated inside the tmux-session branch below, but always fed to
  # wm_state outage-update afterward (owner "" only) so the quiet-period
  # countdown advances in real time even on a poll with nothing to scan.
  _OUTAGE_API_SIGNALS=0
  _reconcile_died=""

  # Wingman's own Remote Control disconnect (ask 2, detect-only - see
  # self_pane_check's own docstring for why this never injects). Checked first,
  # every cycle, independent of $WM_TMUX_SESSION: wingman's own registered pane
  # need not be inside the crew tmux session at all. Fires the ordinary wake
  # contract (wake file + reason line + exit 0) exactly like a crew event below,
  # so wingman's very next turn reports it to the pilot immediately.
  if self_pane_check; then
    {
      echo "# Wingman's own Remote Control session disconnected"
      echo
      echo "This session's own Remote Control connection dropped and its automatic"
      echo "retry budget is exhausted. Run \`/remote-control\` in this session to restore it."
    } > "$WAKEFILE"
    echo "remote-control-dropped: wingman run /remote-control in this session to restore it"
    printf 'remote-control-dropped\n' > "$EXITFILE"
    rm -f "$PIDFILE"
    exit 0
  fi

  # Reconcile liveness so a dead window becomes 'died'. Strays are adopted
  # first (a live window in the wrong session is moved home, never flagged).
  if wm_tmux has-session -t "$WM_TMUX_TARGET" 2>/dev/null; then
    wm_tmux_adopt_strays
    # Pass this cycle's owner so the dead-owner re-adopt pass runs only under
    # wingman's watcher (--owner ""); a lead's cycle does the death-flip only (N4).
    # Captured (not discarded) this time: reconcile prints the ids it JUST
    # flipped to died this call, space-joined - the outage-state signal below
    # (#23, item 0) needs exactly this poll's own death count, not the
    # roster's full died population.
    _reconcile_died="$(wm_state reconcile --windows "$(wm_tmux_windows_csv)" --owner "$OWNER" 2>/dev/null)"

    # Pane backstop over every working OR already-blocked member: two failure
    # shapes never reach the status files on their own. A member frozen on an
    # interactive permission/trust prompt is flipped to blocked (independent of
    # the crew's permission mode, so it still catches freezes when bypass is
    # disabled) - this applies whether the member was "working" or already
    # "blocked" for an unrelated reason (a member can answer one blocker and walk
    # straight into a fresh confirmation dialog, which would otherwise be
    # invisible: the backstop below used to scan only "working" members, so a
    # dialog freeze on top of a pre-existing blocker never got a second look). A
    # member gone silently idle - agent errored, nothing executing - is flipped to
    # stalled by wm-state stall-check; that diagnosis only makes sense for a
    # member that claims to be "working", since a "blocked" member sitting idle
    # is already exactly where it is supposed to be. Both then flow through the
    # normal needs-attention/fire path below.
    #
    # review and stalled are also pulled into this same pane-capture loop
    # (issue #96), but only for Remote Control connection-state tracking - see
    # the review|stalled continue below, which skips them past every
    # freeze/stall diagnostic in this paragraph unchanged.
    for _row in $(wm_state crew-list --owner "$OWNER" --json 2>/dev/null | wm_py -c '
import sys, json
try:
    data = json.load(sys.stdin)
except Exception:
    data = []
for r in data:
    st = r.get("status", "")
    # review/stalled (issue #96): widened so bin/watch-fleet observes a
    # Remote Control connection drop for the actual population
    # bin/crew-standdown hits, not only the working/blocked pair the
    # freeze/stall diagnostics below were originally scoped to. remote_control
    # absent reads as True (see cmd_crew_add in bin/lib/wm-state.py).
    if st in ("working", "blocked", "review", "stalled"):
        rc = "1" if r.get("remote_control", True) else "0"
        print(r.get("id", "") + ":" + st + ":" + rc)
' 2>/dev/null); do
      _id="${_row%%:*}"; _rest="${_row#*:}"; _orig_status="${_rest%%:*}"; _rc_enabled="${_rest#*:}"
      _win="wm-$_id"
      wm_tmux_windows | grep -qx "$_win" || continue
      wm_pane_snapshot "$_id" "$_win"

      # Pane-tail cache (#23, item 1): the last WM_APIERR_TAIL lines of this
      # poll's capture, overwritten in place every poll for every member in
      # this loop's widened population - never a growing log. Once a window
      # dies, this is the last thing we know its pane showed; wm-state
      # reconcile reads it at the moment of the death flip to attribute
      # death_cause.
      printf '%s\n' "$PANE_TEXT" | tail -n "$WM_APIERR_TAIL" \
        > "$WM_HOME/pane-tail-$(printf '%s' "$_id" | tr -c 'A-Za-z0-9._-' '_').txt"

      # Stability-gated drop detection, computed once and shared by the
      # connection-state persistence below and the working-only reconnect
      # attempt beneath it - the same "one more poll before acting" rule
      # prompt_freeze_check and the API-error nudge both use, so a banner
      # merely scrolling transiently through a member's own transcript is
      # never mistaken for a live drop.
      _rc_dropped=0
      [ "$PANE_STABLE" = 1 ] && remote_control_dropped_check && _rc_dropped=1

      # Remote Control connection-state tracking (issue #96): persist this
      # poll's stability-gated observation onto the roster record for every
      # status in the widened population above, so bin/crew-standdown can
      # later read a value already vetted by this same rigor instead of
      # taking its own single-shot, unguardable pane read at standdown time.
      # Deliberately not reset back to true here when no drop is observed -
      # the only writer of "true" after spawn is a successful reconnect send
      # just below, matching the plan's own scope exactly.
      if [ "$_rc_enabled" = 1 ] && [ "$_rc_dropped" = 1 ]; then
        wm_state crew-set --id "$_id" --remote-control-connected false >/dev/null 2>&1
      fi

      # Remote Control auto-recovery (ask 2, crew-side): a settled disconnect
      # banner gets one `/remote-control` retry per cooldown window - the
      # existing message-delivery primitive, aimed at a pane it already has a
      # target for. Purely self-healing: it never changes crew status, so it
      # stays quiet the overwhelming majority of the time. Working members
      # only: an already-blocked member's pane is not expected to be showing a
      # live agent to reconnect.
      if [ "$_orig_status" = working ] && [ "$_rc_dropped" = 1 ]; then
        _rcfile="$WM_HOME/rcdrop-$(printf '%s' "$_id" | tr -c 'A-Za-z0-9._-' '_').sent"
        _rc_age=$(( $(date +%s) - $(wm_py -c 'import os,sys;print(int(os.path.getmtime(sys.argv[1])))' "$_rcfile" 2>/dev/null || echo 0) ))
        if [ ! -f "$_rcfile" ] || [ "$_rc_age" -ge "$RC_DROPPED_COOLDOWN" ]; then
          # Only mark the cooldown when the retry actually sent: a refusal (the
          # pane looks dialog-shaped, not the chat input) means nothing went out,
          # so the next cycle should try again rather than sit out a cooldown for
          # a retry that never happened.
          if wm_tmux_send_message "$(wm_tmux_win_target "$_win")" "/remote-control"; then
            : > "$_rcfile"
            # Reflect the self-heal back into the persisted field the same way
            # a detected drop is (issue #96).
            wm_state crew-set --id "$_id" --remote-control-connected true >/dev/null 2>&1
          fi
        fi
      fi

      # review/stalled were widened into this loop above solely for the
      # Remote Control connection-state tracking just above; none of the
      # freeze/stall diagnostics below apply to them (a review member sitting
      # idle is exactly where it's supposed to be, and prompt_freeze_check's
      # blocked-flip is scoped to the working/blocked population this loop
      # originally covered).
      case "$_orig_status" in
        review|stalled) continue ;;
      esac

      if prompt_freeze_check && ! liveness_veto "$_id"; then
        # Which of the two dialog shapes prompt_freeze_check actually matched
        # (#23/#30) decides the wording: the resume-from-summary menu is a
        # specific, well-understood freeze needing exactly one keypress, not
        # the generic "no one at its terminal" framing of an ordinary
        # permission/trust gate.
        if printf '%s\n' "$PANE_TEXT" | tail -n "$WM_PERM_TAIL" | grep -qE "$WM_RESUME_PROMPT_RE"; then
          _blocker="frozen on the resume-from-summary prompt (issue #30) after an auto-recovery attempt - needs one keypress via bin/crew-takeover $_id"
        else
          _blocker="frozen on a permission/trust prompt with no one at its terminal; approve it via bin/crew-takeover $_id, or relaunch the crew with bypass"
        fi
        wm_state crew-set --id "$_id" --status blocked --blocker "$_blocker" >/dev/null 2>&1
        continue   # the permission freeze is the more specific diagnosis, superseding any prior blocker reason
      fi
      # An already-blocked member with no dialog freeze detected needs no further
      # diagnosis here: its existing blocker reason is left untouched, and the
      # stall/api-error checks below only make sense for a member that claims to
      # be actively working.
      [ "$_orig_status" = blocked ] && continue

      # A prompt-shaped pane whose stability is not yet confirmed (first sighting,
      # no prior hash) is one INTERVAL from a definitive diagnosis; hold the stall
      # check off it, or a dialog frozen longer than STALL_IDLE before our first
      # look would be flipped stalled on poll one and - having left the working
      # scan - never get its confirming second sighting as blocked.
      [ "$PFC_SHAPE" = 1 ] && continue

      # Silent-stall backstop: no pane repaint AND no status update for STALL_IDLE
      # seconds nominates the member; stall-check probes its process tree and flags
      # it stalled only if nothing there is executing or armed to wake it.
      _idle="$(wm_tmux_window_activity_age "$_win")"
      _pid="$(wm_tmux_pane_pid "$_win")"

      # Stall self-heal nudge (#61): every stall-idle candidate gets exactly one
      # check-in nudge before stall-check is even allowed to confirm+flip it -
      # not only an api-error match. Only acted on once stability is confirmed
      # (PANE_STABLE), the same "one more poll before acting" rule
      # prompt_freeze_check uses above - otherwise a pane still scrolling mid-turn
      # would be nudged for no reason. --nudge-age (-1 if no marker exists yet) is
      # passed straight through to stall-check, which flips only once that age
      # reaches --threshold (STALL_IDLE) - the same wait window used for the
      # staleness gates themselves, not a separate constant. The nudge is sent
      # if and only if no marker exists yet (this is the first confirmed-idle
      # poll of this stall episode) and is NEVER re-sent afterward: a resend
      # gated on its own separate cooldown previously let that cooldown and
      # stall-check's --threshold gate drift apart (#101) - tuned equal by
      # default they raced (a duplicate nudge landed on the same poll as the
      # flip), and tuned apart the marker could keep resetting itself and the
      # member would never escalate at all. Marker-existence-only sending makes
      # that impossible: once sent, the marker's age can only grow.
      _api=0
      _nudge_age=-1
      if [ "$_idle" -ge "$STALL_IDLE" ]; then
        if [ "$PANE_STABLE" != 1 ]; then
          continue   # first sighting or still changing; one more poll before acting
        fi
        # Computed every poll, not only the one that sends the nudge: --api-error
        # feeds stall-check's reason-text choice on whichever poll eventually
        # flips it, which is almost never the same poll as the send.
        if api_error_check; then
          _api=1
          # Fleet-wide outage signal (#23, item 0): this poll's count of
          # working members currently showing the API-error signature, fed
          # to wm_state outage-update below (owner "" only) after this loop.
          _OUTAGE_API_SIGNALS=$((_OUTAGE_API_SIGNALS+1))
          _nudge_msg="An API/connectivity error appears to have interrupted your last turn (rate limit, network blip, or a brief Anthropic-side outage). This is usually transient - please retry your last action."
        else
          _nudge_msg="Checking in: if you're mid-task, keep going. If you're stuck, unstick yourself and continue."
        fi
        _nudgefile="$WM_HOME/stall-$(printf '%s' "$_id" | tr -c 'A-Za-z0-9._-' '_').nudged"
        if [ -f "$_nudgefile" ]; then
          _nudge_age=$(( $(date +%s) - $(wm_py -c 'import os,sys;print(int(os.path.getmtime(sys.argv[1])))' "$_nudgefile" 2>/dev/null || date +%s) ))
        else
          # Only mark the episode nudged when the nudge actually sent, not when
          # wm_tmux_send_message refused because the pane looks dialog-shaped
          # rather than the chat input - a refusal must be retried, not treated
          # as delivered.
          if wm_tmux_send_message "$(wm_tmux_win_target "$_win")" "$_nudge_msg"; then
            : > "$_nudgefile"
          fi
        fi
      fi

      [ -n "$_pid" ] && wm_state stall-check --id "$_id" \
        --nudge-age "$_nudge_age" \
        --pane-idle "$_idle" --pane-pid "$_pid" --threshold "$STALL_IDLE" \
        --root-grace "$STALL_ROOT_GRACE" --probe-gap "$STALL_PROBE_GAP" \
        --cpu-eps "$STALL_CPU_EPS" --api-error "$_api" >/dev/null 2>&1
    done
  fi

  # Fleet-wide outage-state machine (#23, item 0): advanced every iteration,
  # wingman's own top-level cycle only (owner "" - concurrency/outage is
  # fleet-wide, not per-lead-team; a lead's cycle skips this entirely).
  # Unlike self_pane_check above, this is deliberately NOT a sixth/seventh
  # top-level --classify outcome: it writes $EXITFILE "fire" (the same token
  # the ordinary fire() path below writes) so outage-detected/outage-cleared
  # surface as ordinary fire reasons within the existing five-outcome
  # classification (healthy/fire/remote-control-dropped/spurious/spurious-
  # repeated) - structurally identical to a blocked/review/done/died/stalled
  # reason line today, just fleet-scoped (no per-member id to ack) rather
  # than routed through fire()'s needs-attention/group-attention machinery.
  if [ -z "$OWNER" ]; then
    _died_csv="$(printf '%s' "$_reconcile_died" | tr ' ' ',')"
    _outage_transition="$(wm_state outage-update --owner "" \
      --signal-working "$_OUTAGE_API_SIGNALS" --died "$_died_csv" \
      --mass-min-count "$MASS_MIN_COUNT" --mass-min-ratio "$MASS_MIN_RATIO" \
      --quiet-seconds "$WM_OUTAGE_QUIET" 2>/dev/null)"
    case "$_outage_transition" in
      outage-detected)
        {
          echo "# API outage detected (issue #23)"
          echo
          echo "Anthropic API-error signals (529/5xx/rate-limit/connection signatures) have"
          echo "crossed the fleet-wide mass threshold - treat this as a likely outage, not"
          echo "isolated incidents."
          echo
          echo "New spawns are now PAUSED: hooks/api-outage-spawn-guard.sh denies"
          echo "bin/spawn-crew while this state is active (override per-spawn with"
          echo "--force-during-outage if one is genuinely needed regardless)."
          echo
          echo "Already-running crew are NOT affected - only new spawns are held."
          echo
          echo "This clears automatically once the signal quiets down for ${WM_OUTAGE_QUIET}s;"
          echo "your next watch-fleet cycle fires outage-cleared the moment it does."
        } > "$WAKEFILE"
        echo "outage-detected: fleet-wide API-error signal crossed the mass threshold - new spawns paused (bin/spawn-crew denied by hooks/api-outage-spawn-guard.sh; override with --force-during-outage if truly needed). Already-running crew are untouched."
        printf 'fire\n' > "$EXITFILE"
        rm -f "$PIDFILE"
        exit 0
        ;;
      outage-cleared)
        _outage_died_ids="$(wm_state crew-list --status died --json 2>/dev/null | wm_py -c '
import sys, json
try:
    data = json.load(sys.stdin)
except Exception:
    data = []
print(" ".join(r.get("id", "") for r in data if r.get("death_cause") == "api-outage"))
' 2>/dev/null)"
        {
          echo "# API outage cleared (issue #23)"
          echo
          echo "The fleet-wide API-error signal has been quiet for ${WM_OUTAGE_QUIET}s. New"
          echo "spawns are unpaused."
          echo
          if [ -n "$_outage_died_ids" ]; then
            echo "Outage-tagged died member(s): $_outage_died_ids"
            echo
            echo "Per the pilot's pre-authorized auto-recovery for this case (CLAUDE.md,"
            echo "\"Mass death or correlated outage detected\"): run \`bin/crew-resume --all-died\`"
            echo "now, without asking for confirmation, then report the outcome."
          else
            echo "No member is currently died with death_cause=api-outage, so there is"
            echo "nothing to auto-resume."
          fi
        } > "$WAKEFILE"
        echo "outage-cleared: fleet-wide API-error signal has quieted for ${WM_OUTAGE_QUIET}s - new spawns unpaused.${_outage_died_ids:+ Outage-tagged died member(s) ($_outage_died_ids): pre-authorized auto-recovery, run bin/crew-resume --all-died now.}"
        printf 'fire\n' > "$EXITFILE"
        rm -f "$PIDFILE"
        exit 0
        ;;
    esac
  fi

  # Proactive usage-limit-quota state machine (#24): advanced every
  # iteration, wingman's own top-level cycle only (owner "" - the account's
  # usage quota is shared fleet-wide, never per-lead-team). Aggregates every
  # $WM_HOME/usage/<session-id>.json (written by bin/lib/usage-statusline.py,
  # the installed statusLine command) into the max used_percentage/resets_at
  # per window among readings that are both fresh (captured_at within
  # WM_USAGE_STALE_SECS) and live (resets_at still in the future - see
  # wm_state usage-update's own docstring for why a frozen high reading
  # cannot be trusted on captured_at freshness alone). Dispatched as an
  # ordinary `fire` reason line within the existing five-outcome --classify
  # contract, exactly like outage-detected/outage-cleared above - no new
  # --classify outcome is introduced.
  if [ -z "$OWNER" ]; then
    _usage_agg="$(wm_py -c '
import datetime, glob, json, os, sys, time

home = os.environ.get("WINGMAN_HOME") or os.path.expanduser("~/.wingman")
stale_secs = float(sys.argv[1])
now = time.time()


def parse_iso(stamp):
    if not stamp:
        return None
    s = stamp[:-1] if stamp.endswith("Z") else stamp
    for fmt in ("%Y-%m-%dT%H:%M:%S.%f", "%Y-%m-%dT%H:%M:%S"):
        try:
            dt = datetime.datetime.strptime(s, fmt).replace(tzinfo=datetime.timezone.utc)
            return dt.timestamp()
        except ValueError:
            continue
    return None


best = {}
for path in glob.glob(os.path.join(home, "usage", "*.json")):
    try:
        with open(path) as fh:
            rec = json.load(fh)
    except (OSError, ValueError):
        continue
    if not isinstance(rec, dict):
        continue
    captured = parse_iso(rec.get("captured_at"))
    if captured is None or (now - captured) > stale_secs:
        continue
    for window in ("five_hour", "seven_day"):
        w = rec.get(window)
        if not isinstance(w, dict):
            continue
        pct = w.get("used_percentage")
        resets_at = w.get("resets_at")
        if not isinstance(pct, (int, float)) or not isinstance(resets_at, (int, float)):
            continue
        if resets_at <= now:
            continue
        cur = best.get(window)
        if cur is None or pct > cur[0]:
            best[window] = (pct, resets_at)

five = best.get("five_hour", ("", ""))
seven = best.get("seven_day", ("", ""))
print("%s\t%s\t%s\t%s" % (five[0], five[1], seven[0], seven[1]))
' "$WM_USAGE_STALE_SECS" 2>/dev/null)"
    IFS=$'\t' read -r _usage_five_pct _usage_five_reset _usage_seven_pct _usage_seven_reset <<EOF_USAGE
$_usage_agg
EOF_USAGE

    _usage_transition="$(wm_state usage-update --owner "" \
      ${_usage_five_pct:+--five-hour-pct "$_usage_five_pct" --five-hour-resets-at "$_usage_five_reset"} \
      ${_usage_seven_pct:+--seven-day-pct "$_usage_seven_pct" --seven-day-resets-at "$_usage_seven_reset"} \
      --warn-threshold "$WM_USAGE_WARN_THRESHOLD" 2>/dev/null)"
    case "$_usage_transition" in
      usage-limit-approaching)
        _usage_info="$(wm_py -c '
import json, os

home = os.environ.get("WINGMAN_HOME") or os.path.expanduser("~/.wingman")
try:
    with open(os.path.join(home, "usage-limit-state.json")) as fh:
        d = json.load(fh)
except (OSError, ValueError):
    d = {}
window_label = {"five_hour": "5-hour", "seven_day": "7-day"}.get(d.get("window"), d.get("window") or "usage")
pct = d.get("used_percentage")
pct_text = ("%.0f%%" % pct) if isinstance(pct, (int, float)) else "an unknown amount"
resets_at = d.get("resets_at")
print("%s\t%s\t%s" % (window_label, pct_text, resets_at if resets_at is not None else "an unknown time"))
' 2>/dev/null)"
        IFS=$'\t' read -r _usage_window_label _usage_pct_text _usage_resets_at <<EOF_USAGE
$_usage_info
EOF_USAGE
        {
          echo "# Usage-limit quota approaching (issue #24)"
          echo
          echo "The $_usage_window_label usage window is at $_usage_pct_text, resets at"
          echo "epoch $_usage_resets_at."
          echo
          echo "New spawns are now PAUSED: hooks/usage-limit-spawn-guard.sh denies"
          echo "bin/spawn-crew while this state is approaching/paused (override per-spawn"
          echo "with --force-during-usage-limit if one is genuinely needed regardless)."
          echo
          echo "Already-running crew are NOT affected by this pause - only new spawns are"
          echo "held. This does NOT park or checkpoint in-flight crew: a member already"
          echo "running keeps consuming quota and can still hit the hard limit mid-turn on"
          echo "its own, whichever way the pilot answers below."
          echo
          echo "Ask the pilot (wait for the reset, or continue anyway and accept the risk),"
          echo "then record the answer immediately with \`\$WINGMAN_STATE usage-decide"
          echo "--decision wait|continue\`."
        } > "$WAKEFILE"
        echo "usage-limit-approaching: $_usage_window_label usage window at $_usage_pct_text (resets at epoch $_usage_resets_at) - new spawns paused (bin/spawn-crew denied by hooks/usage-limit-spawn-guard.sh; override with --force-during-usage-limit if truly needed). Already-running crew are untouched and can still hit the hard limit on their own. Ask the pilot wait-vs-continue and record the answer with usage-decide."
        printf 'fire\n' > "$EXITFILE"
        rm -f "$PIDFILE"
        exit 0
        ;;
      usage-limit-reset)
        {
          echo "# Usage-limit window reset (issue #24)"
          echo
          echo "The usage window has reset on its own. New spawns are unpaused again -"
          echo "nothing further to do."
        } > "$WAKEFILE"
        echo "usage-limit-reset: the usage window reset - new spawns unpaused again."
        printf 'fire\n' > "$EXITFILE"
        rm -f "$PIDFILE"
        exit 0
        ;;
    esac
  fi

  # Who needs this owner right now? Scoped to the owner's own direct reports, so a
  # lead's worker never wakes wingman and vice versa. Checked at the top of the loop
  # so an event already pending on arm fires immediately (at-least-once re-arms).
  # --suppress-on ack (the default, explicit here) is the watcher/fire gate: an
  # event already acked (surfaced and in flight) or handled does not re-fire, while
  # a new (id, updated) still surfaces. The Stop hook uses --suppress-on handled so
  # an acked-but-unhandled event still blocks once (Fix A / #8).
  attention="$(wm_state needs-attention --owner "$OWNER" --suppress-on ack 2>/dev/null)"
  [ -n "$attention" ] && fire "$attention"

  sleep "$INTERVAL"
done
